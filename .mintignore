# All plain markdown files — Mintlify parses as MDX causing failures; all pages use .mdx
**/*.md

# Bare node_modules — Mintlify's ignore parser doesn't reliably handle ** globs
node_modules

# Compatibility aliases for simpler ignore parsers
/.github
/workspace
/_dep-docs
/tools/notion
/docs-guide/_workspace

# Explicit nested dependency dirs
tests/node_modules
tools/node_modules

# Dependencies and build artifacts
**/node_modules/**
**/.cache/**
**/coverage/**
**/dist/**
.mintlify/
.mintlify-cache/
.out/

# Non-doc operational directories
/.github/**
/workspace/**
/ai-tools/**
/.githooks/**
/.vscode/**
/tools/notion/**
/tools/**/*.js
/tools/**/*.jsx

# Runtime-only local assets that must never be injected into browser pages
/snippets/automations/**/*.js

# Temporary and backup files
tmp_*
**/*.tmp
**/*.temp
**/*.bak*
**/*.disabled

# Root folder _workspace/ dirs (ai-tools, api, snippets, tools)
/ai-tools/_workspace/**
/api/_workspace/**
/snippets/_workspace/**
/tools/_workspace/**

# V2 draft / scratch / context-only content / deprecated
/v2/**/x-archived/**
/v2/**/x-deprecated/**
/v2/**/x-experimental/**
/v2/**/x-notes/**
/v2/**/x-pages/**
/v2/**/x-unstaged/**
/v2/**/_workspace/**
/v2/**/_contextData/**
/v2/**/_contextData_/**
/v2/**/_context_data_/**
/v2/**/_plans-and-research/**
/v2/**/x-resources/**
/v2/**/TO-ADD/**
/v2/**/_archive/**
/v2/**/_tests-to-delete/**
/v2/**/_move_me/**
/v2/**/review.md
/v2/**/todo.txt
/v2/**/todo.mdx
/v2/NOTES_V2.md

# Unrouted internal source/report artifacts
/v2/internal/assets/transcripts/**
/v2/internal/layout-components-scripts-styling/**
/v2/internal/ally-notes.mdx
/v2/internal/marketing-posts.md
/v2/internal/marketing-posts-v2.md
/v2/internal/reports/repo-ops/audit-tasks-folders--*.md
/v2/internal/rfp/reports/livepeer-docs-v2-report.md

# Un-ignore report pages and templates that are referenced in nav
!/v2/internal/reports/**
!/docs-guide/tooling/content-brief-template.md

# Un-ignore ai-tools setup guide pages that are referenced in nav
!/ai-tools/claude-code.mdx
!/ai-tools/cursor.mdx
!/ai-tools/windsurf.mdx

# Tooling markdown docs not intended as docs-site pages
/tools/**/*.md
/tools/**/*.mdx
!/tools/scripts/snippets/README.mdx

# Snippets docs/examples not intended as routable pages
/snippets/README.md
/snippets/assets/README.mdx
/snippets/assets/scripts/n8n/README-*.md
/snippets/components/**/README.md
/snippets/components/**/examples/**
/snippets/components/layout/examples/README-custom-view.md
/snippets/data/API/README.md
/snippets/automations/showcase/README.md
/snippets/composables/**

# Generated artifacts
docs-index.json
llms.txt
sitemap-ai.xml

# AI files
.cursorrules
.allowlist
