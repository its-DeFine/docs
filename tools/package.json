{
  "name": "livepeer-docs-tools",
  "version": "1.0.0",
  "description": "Livepeer documentation tools, validators, and generators",
  "private": true,
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@mintlify/scraping": "^3.0.66",
    "chalk": "^4.1.2",
    "cspell-lib": "^8.17.3",
    "glob": "^11.0.1",
    "gray-matter": "^4.0.3",
    "js-sha3": "^0.9.3",
    "js-yaml": "^4.1.0",
    "node-html-parser": "^7.0.1",
    "open": "^8.4.2",
    "openai": "^4.77.3",
    "prettier": "^3.5.3",
    "puppeteer": "^24.2.0",
    "rehype-parse": "^9.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5"
  },
  "scripts": {
    "codex:chat:list": "node ../tools/dev/editor/rename-vscode-codex-chat.js --list",
    "codex:chat:rename": "node ../tools/dev/editor/rename-vscode-codex-chat.js",
    "vscode:authoring-tools:install": "bash ../tools/editor-extensions/install.sh",
    "vscode:authoring-tools:package": "cd vscode/authoring-tools && ../../node_modules/.bin/vsce package -o livepeer-authoring-tools.vsix",
    "vscode:markdown-list:package": "cd vscode/markdown-list && ../../node_modules/.bin/vsce package -o livepeer-markdown-list-tools.vsix",
    "format-mdx": "node ../tools/dev/authoring/format-mdx.js --write",
    "format-mdx:check": "node ../tools/dev/authoring/format-mdx.js --check",
    "audit:scripts": "node ../operations/scripts/audits/governance/scripts/audit-script-categories.js",
    "audit:repo": "node ../operations/scripts/dispatch/governance/repo/repo-audit-orchestrator.js --mode static --scope full",
    "audit:repo:changed": "node ../operations/scripts/dispatch/governance/repo/repo-audit-orchestrator.js --mode static --scope changed",
    "audit:repo:full": "node ../operations/scripts/dispatch/governance/repo/repo-audit-orchestrator.js --mode full --scope full",
    "audit:repo:quarantine": "node ../operations/scripts/dispatch/governance/repo/repo-audit-orchestrator.js --mode static --scope full --quarantine",
    "audit:repo:pack-all": "node ../operations/scripts/dispatch/governance/repo/repo-audit-orchestrator.js --mode static --scope full --agent-pack all",
    "audit:component-layout": "node ../operations/scripts/validators/components/library/component-layout-governance.js --scope full",
    "audit:docs-quality": "node ../operations/scripts/audits/content/quality/docs-quality-and-freshness-audit.js --scope full",
    "audit:page-links": "node ../operations/scripts/audits/content/health/page-links-audit.js",
    "audit:page-imports": "node ../operations/scripts/audits/content/health/page-imports-audit.js",
    "audit:page-integrity": "node ../operations/scripts/dispatch/content/health/page-integrity-dispatch.js",
    "audit:language-en-gb": "node ../operations/scripts/audits/content/style/style-and-language-homogenizer-en-gb.js --scope full",
    "report:component-governance-remediation": "node ../operations/scripts/audits/governance/reports/generate-component-governance-remediation-reports.js",
    "registry:components": "node ../operations/scripts/generators/components/library/generate-component-registry.js",
    "cleanup:classify": "node ../operations/scripts/remediators/content/repair/quarantine-manager.js",
    "cleanup:quarantine": "node ../operations/scripts/remediators/content/repair/quarantine-manager.js --apply",
    "repair:mdx-safe-markdown": "node ../operations/scripts/remediators/content/repair/repair-mdx-safe-markdown.js --write",
    "repair:page-links": "node ../operations/scripts/remediators/content/repair/repair-page-links.js --write",
    "repair:page-imports": "node ../operations/scripts/remediators/content/repair/repair-page-imports.js --write",
    "repair:mdx-safe-markdown:dry-run": "node ../operations/scripts/remediators/content/repair/repair-mdx-safe-markdown.js --dry-run",
    "repair:governance": "node ../operations/scripts/dispatch/governance/pipelines/governance-pipeline.js",
    "review:governance:repair": "node ../operations/scripts/validators/governance/compliance/review-governance-repair-checklist.js",
    "pack:agents": "node ../operations/scripts/automations/ai/agents/cross-agent-packager.js --agent-pack all",
    "skills:sync:codex": "node ../operations/scripts/automations/ai/agents/sync-codex-skills.js",
    "skills:sync:codex:check": "node ../operations/scripts/automations/ai/agents/sync-codex-skills.js --check",
    "codex:pr": "node ../operations/scripts/dispatch/ai/codex/create-codex-pr.js --create",
    "codex:pr:advisory": "node ../operations/scripts/dispatch/ai/codex/create-codex-pr.js --advisory-research",
    "codex:pr:research": "node ../operations/scripts/dispatch/content/veracity/docs-page-research-pr-report.js --registry workspace/research/claims",
    "codex:pr:research:legacy": "node ../operations/scripts/docs-claim-ledger-pr-report.js --ledger workspace/reports/repo-ops/page-content-claim-ledger.json",
    "docs-guide:indexes": "node ../operations/scripts/generators/governance/catalogs/generate-docs-guide-indexes.js --write",
    "fetch-docs": "bash ../operations/scripts/automations/content/data/fetching/fetch-external-docs.sh",
    "generate-seo": "node ../operations/scripts/remediators/content/seo/generate-seo.js",
    "generate-seo:dry-run": "node ../operations/scripts/remediators/content/seo/generate-seo.js --dry-run",
    "prebuild": "bash ../operations/scripts/automations/content/data/fetching/fetch-external-docs.sh",
    "test:v2-pages": "node ../operations/scripts/validators/content/structure/test-v2-pages.js",
    "test": "node ../operations/tests/run-all.js",
    "test:style": "node ../operations/tests/unit/style-guide.test.js",
    "test:mdx": "node ../operations/tests/unit/mdx.test.js",
    "test:mdx:safe": "node ../operations/scripts/validators/content/structure/check-mdx-safe-markdown.js",
    "test:spell": "node ../operations/tests/unit/spelling.test.js",
    "test:links": "node ../operations/tests/unit/links.test.js",
    "test:imports": "node ../operations/tests/unit/imports.test.js",
    "test:browser": "node ../operations/tests/integration/browser.test.js",
    "test:browser:all": "node ../operations/tests/integration/browser.test.js",
    "test:quality": "node ../operations/tests/unit/quality.test.js",
    "test:all-pages": "node ../operations/scripts/validators/content/structure/test-v2-pages.js",
    "i18n:translate": "node ../operations/scripts/automations/content/language-translation/translate-docs.js",
    "i18n:docs-json": "node ../operations/scripts/automations/content/language-translation/generate-localized-docs-json.js",
    "i18n:validate": "node ../operations/scripts/automations/content/language-translation/validate-generated.js",
    "test:i18n": "node --test ../operations/scripts/automations/content/language-translation/test/*.test.js"
  },
  "devDependencies": {
    "flatted": "^3.4.2",
    "picomatch": "^4.0.4"
  }
}
