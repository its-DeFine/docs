{
  "name": "livepeer-component-picker",
  "displayName": "Livepeer Component Picker",
  "description": "Browse, insert, and wrap with Livepeer docs components by category.",
  "version": "0.0.1",
  "publisher": "livepeer",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/livepeer/docs.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Snippets",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:mdx",
    "onLanguage:markdown"
  ],
  "main": "./extension.js",
  "files": [
    "extension.js",
    "component-registry.json",
    "README.md",
    "package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "livepeer.insertComponent",
        "title": "Livepeer: Insert Component"
      },
      {
        "command": "livepeer.wrapWithComponent",
        "title": "Livepeer: Wrap with Component"
      }
    ]
  },
  "scripts": {
    "package": "npx @vscode/vsce package"
  }
}
