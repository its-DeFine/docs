{
  "version": "0.2",
  "language": "en-GB",
  "dictionaryDefinitions": [
    {
      "name": "livepeer-terms",
      "path": "./operations/tests/config/spell-dict.json",
      "addWords": true
    }
  ],
  "dictionaries": [
    "en-gb",
    "typescript",
    "node",
    "npm",
    "html",
    "css",
    "bash",
    "docker",
    "markdown",
    "livepeer-terms"
  ],
  "ignoreWords": [
    "mdx",
    "jsx",
    "frontmatter",
    "Mintlify",
    "livepeer",
    "Livepeer"
  ],
  "ignorePaths": [
    "node_modules/**",
    "package-lock.json",
    "*.log",
    ".git/**",
    "v1/**",
    "snippets/assets/**",
    "**/*.min.js",
    "**/*.bundle.js"
  ],
  "flagWords": [
    "color",
    "colors",
    "colored",
    "colorful",
    "optimize",
    "optimized",
    "optimizing",
    "optimization",
    "organize",
    "organized",
    "organizing",
    "organization",
    "recognize",
    "recognized",
    "recognizing",
    "customize",
    "customized",
    "customization",
    "minimize",
    "minimized",
    "maximize",
    "maximized",
    "utilize",
    "utilized",
    "utilization",
    "analyze",
    "analyzed",
    "analyzing",
    "authorize",
    "authorized",
    "authorization",
    "centralize",
    "centralized",
    "decentralize",
    "decentralized",
    "incentivize",
    "incentivized",
    "initialize",
    "initialized",
    "initialization",
    "finalize",
    "finalized",
    "normalize",
    "normalized",
    "normalization",
    "standardize",
    "standardized",
    "standardization",
    "specialize",
    "specialized",
    "specialization",
    "synchronize",
    "synchronized",
    "stabilize",
    "stabilized",
    "prioritize",
    "prioritized",
    "monetize",
    "monetized",
    "monetization",
    "tokenize",
    "tokenized",
    "tokenization",
    "visualize",
    "visualized",
    "visualization",
    "behavior",
    "behaviors",
    "favor",
    "favorite",
    "favorites",
    "honor",
    "honored",
    "neighbor",
    "neighbors",
    "labor",
    "humor",
    "vigor",
    "center",
    "centered",
    "fiber",
    "fibers",
    "defense",
    "offense",
    "catalog",
    "catalogs",
    "gray"
  ],
  "overrides": [
    {
      "filename": "**/*.mdx",
      "languageSettings": [
        {
          "languageId": "markdown",
          "locale": "en-GB"
        }
      ]
    },
    {
      "filename": "**/*.js",
      "languageSettings": [
        {
          "languageId": "javascript",
          "locale": "en-US"
        }
      ]
    },
    {
      "filename": "**/*.jsx",
      "languageSettings": [
        {
          "languageId": "javascript",
          "locale": "en-US"
        }
      ]
    }
  ]
}
