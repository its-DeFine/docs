{
  "version": "1.0",
  "description": "Proper noun capitalisation rules for Livepeer documentation. Context 'prose' means skip code, frontmatter, URLs, imports, JSX attributes.",
  "rules": [
    { "term": "Livepeer", "pattern": "\\blivepeer\\b", "replacement": "Livepeer", "tier": 1, "context": "prose", "exceptions": ["livepeer.org", "livepeer-", "go-livepeer", "@livepeer", "livepeer.js", "livepeer-js", "livepeer-go", "livepeer-python", "livepeer-ai"] },
    { "term": "Orchestrator", "pattern": "\\borchestrator(s?)\\b", "replacement": "Orchestrator$1", "tier": 1, "context": "prose", "exceptions": ["--orchestrator", "orchSecret"] },
