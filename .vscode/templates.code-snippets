  "Page Template: {Product} — Community & Updates": {
    "scope": "mdx,markdown",
    "prefix": "lp-social-data",
    "body": [
      "---",
      "title: '${1:{Product} — Community & Updates Title}'",
      "sidebarTitle: 'Community & Updates'",
      "description: '${2:Describe the page intent and the reader outcome.}'",
      "audience: builder",
      "pageType: resource",
      "purpose: orient",
      "status: draft",
      "lastVerified: ${3:YYYY-MM-DD}",
      "keywords:",
      "  - {product}",
      "  - livepeer",
      "  - community",
      "  - updates",
      "'og:image': /snippets/assets/site/og-image/fallback.png",
      "'og:image:alt': Livepeer Docs social preview image",
      "'og:image:type': image/png",
      "'og:image:width': 1200",
      "'og:image:height': 630",
      "---",
      "",
      "{/* ─── IMPORTS ─────────────────────────────────────────────────────────── */}",
      "{/* Component imports — uncomment the sections you need */}",
      "",
      "import { YouTubeVideo } from '/snippets/components/displays/video/Video.jsx'",
      "import { YouTubeVideoData } from '/snippets/components/integrators/video-data/VideoData.jsx'",
      "import { PostCard, BlogCard, CardBlogDataLayout, CardColumnsPostLayout, ColumnsBlogCardLayout, ForumLatestLayout, DiscordAnnouncements } from '/snippets/components/integrators/blog/Data.jsx'",
      "import { MarkdownEmbed } from '/snippets/components/integrators/embeds/DataEmbed.jsx'",
      "import { LinkArrow } from '/snippets/components/elements/links/Links.jsx'",
      "import { CustomDivider } from '/snippets/components/elements/spacing/Divider.jsx'",
      "",
      "{/* ─── DATA IMPORTS ────────────────────────────────────────────────────── */}",
      "{/* Swap these for the product-specific data files from snippets/automations/{product}/ */}",
      "",
      "{/* import { youtubeData } from '/snippets/automations/{product}/youtubeData.jsx' */}",
      "{/* import { {product}BlogData } from '/snippets/automations/{product}/blogData.jsx' */}",
      "{/* import { {product}DiscordData } from '/snippets/automations/{product}/discordData.jsx' */}",
      "{/* import { {product}DiscussionsData } from '/snippets/automations/{product}/githubDiscussionsData.jsx' */}",
      "{/* import { {product}ReleasesData } from '/snippets/automations/{product}/githubReleasesData.jsx' */}",
      "",
      "<Tip>",
      "  Uses automations to pull in the latest YouTube videos, GitHub activity, blog posts, and community updates for {Product}.",
      "</Tip>",
      "",
      "{/* ─── HERO VIDEO ──────────────────────────────────────────────────────── */}",
      "{/* Replace with the product's hero/intro video. Priority: YouTube embed > self-hosted MP4 */}",
      "",
      "<YouTubeVideo",
      "  embedUrl=\"https://www.youtube.com/embed/{VIDEO_ID}\"",
      "  caption=\"{Product} — an introduction to the project and its mission.\"",
      "/>",
      "",
      "<CustomDivider />",
      "",
      "{/* ─── YOUTUBE VIDEOS ──────────────────────────────────────────────────── */}",
      "",
      "## <Icon icon=\"camera-movie\" size={24} /> Videos",
      "",
      "Watch the latest videos on the <LinkArrow label=\"{Product} YouTube Channel\" href=\"https://www.youtube.com/channel/{CHANNEL_ID}\" newline={false} />",
      "",
      "{/* <YouTubeVideoData items={youtubeData} limit={2} /> */}",
      "",
      "<CustomDivider />",
      "",
      "{/* ─── GITHUB README ───────────────────────────────────────────────────── */}",
      "",
      "## <Icon icon=\"github\" size={24} /> GitHub",
      "",
      "<MarkdownEmbed url=\"https://raw.githubusercontent.com/{org}/{repo}/{branch}/README.md\" />",
      "",
      "<LinkArrow label=\"View on GitHub\" href=\"https://github.com/{org}/{repo}\" newline={false} />",
      "",
      "<CustomDivider />",
      "",
      "{/* ─── GITHUB RELEASES / CHANGELOG ─────────────────────────────────────── */}",
      "{/* Conditional — include only if product has active GitHub Releases */}",
      "",
      "{/*",
      "## <Icon icon=\"tag\" size={24} /> Releases",
      "",
      "See the latest changes on the <LinkArrow label=\"{Product} GitHub Releases\" href=\"https://github.com/{org}/{repo}/releases\" newline={false} />",
      "",
      "Display releases data component here — e.g. a card list from {product}ReleasesData",
      "*/}",
      "",
      "{/* ─── DISCORD ANNOUNCEMENTS ──────────────────────────────────────────── */}",
      "{/* Conditional — include only if product has a Discord with announcements channel */}",
      "",
      "{/*",
      "## <Icon icon=\"discord\" size={24} /> Discord",
      "",
      "Add your voice to the latest <LinkArrow label=\"{Product} Discord\" href=\"{DISCORD_INVITE_URL}\" newline={false} />",
      "",
      "<DiscordAnnouncements items={{product}DiscordData} limit={2} />",
      "*/}",
      "",
      "<CustomDivider />",
      "",
      "{/* ─── X / TWITTER ─────────────────────────────────────────────────────── */}",
      "{/* Static approach — link to product X profile. No paid widget. */}",
      "",
      "## <Icon icon=\"twitter\" size={24} /> X / Twitter",
      "",
      "Follow, Like, Comment & Share on <LinkArrow label=\"{Product} on X\" href=\"https://x.com/{HANDLE}\" newline={false} />",
      "",
      "{/*",
      "NOTE FOR IMPLEMENTERS:",
      "The community trending-topics page uses a paid mikle.com live-feed widget (ID 176804).",
      "If this product wants a live X feed, they must create and fund their own mikle.com or",
      "sociablekit.com widget and pass the widgetId prop to TwitterTimeline.",
      "Otherwise, use a static link or embed a pinned tweet via oEmbed.",
      "*/}",
      "",
      "<CustomDivider />",
      "",
      "{/* ─── BLOG ────────────────────────────────────────────────────────────── */}",
      "{/* Conditional — include only if product has a blog with public API/RSS */}",
      "",
      "{/*",
      "## <Icon icon=\"pencil-line\" size={24} /> Blog",
      "",
      "Read recent news from the <LinkArrow label=\"{Product} Blog\" href=\"{BLOG_URL}\" newline={false} />",
      "",
      "<ColumnsBlogCardLayout items={{product}BlogData} limit={2} />",
      "*/}",
      "",
      "{/* ─── FORUM / GITHUB DISCUSSIONS ──────────────────────────────────────── */}",
      "{/* Conditional — Discourse forum OR GitHub Discussions, not both */}",
      "",
      "{/*",
      "## <Icon icon=\"messages\" size={24} /> Discussions",
      "",
      "Contribute to the latest <LinkArrow label=\"{Product} Discussions\" href=\"{FORUM_OR_DISCUSSIONS_URL}\" newline={false} />",
      "",
      "If Discourse: <ForumLatestLayout items={{product}ForumData} limit={2} />",
      "If GitHub Discussions: display from {product}DiscussionsData",
      "*/}",
      "",
      "<CustomDivider />",
      "",
      "{/* ─── RELATED PAGES ──────────────────────────────────────────────────── */}",
      "",
      "## Related Pages",
      "",
      "<CardGroup cols={2}>",
      "  <Card title=\"{Product} Overview\" icon=\"book-open\" href=\"/solutions/{product}/overview\" />",
      "  <Card title=\"{Product} Quickstart\" icon=\"rocket\" href=\"/solutions/{product}/quickstart\" />",
      "</CardGroup>"
