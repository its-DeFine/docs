      "    <TableCell>`category-a`</TableCell>",
      "    <TableCell>What belongs here and the decision rule for classifying items into this category.</TableCell>",
      "    <TableCell>`path/to/category-a/`</TableCell>",
      "    <TableCell>`ExampleItem.jsx`</TableCell>",
      "  </TableRow>",
      "  <TableRow>",
      "    <TableCell>`category-b`</TableCell>",
      "    <TableCell>What belongs here and the decision rule for classifying items into this category.</TableCell>",
      "    <TableCell>`path/to/category-b/`</TableCell>",
      "    <TableCell>`AnotherItem.jsx`</TableCell>",
      "  </TableRow>",
      "</StyledTable>",
      "",
      "<CustomDivider />",
      "",
      "## Item Specification",
