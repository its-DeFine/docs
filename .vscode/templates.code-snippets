      "audience: community",
      "pageType: reference",
      "purpose: reference",
      "status: current",
      "lastVerified: ${3:Fri Mar 20 2026 11:00:00 GMT+1100 (Australian Eastern Daylight Time)}",
      "keywords:",
      "  - livepeer",
      "  - source of truth",
      "  - governance",
      "  - reference",
      "  - canonical",
      "'og:image': /snippets/assets/site/og-image/fallback.png",
      "'og:image:alt': Livepeer Docs social preview image",
      "'og:image:type': image/png",
