      "---",
      "",
      "{/* IMPORTS */}",
      "\"import { Quote } from '/snippets/components/displays/quotes/Quote.jsx'\"\"",
      "",
      "{/* ==========================PAGE SECTION: HEADER========================= */}",
      "{/*",
      "PAGE SECTION: HEADER:",
      "- PAGE ELEMENT: Frontmatter Title",
