      "<Card",
      "  title=\"Common Issues\"",
      "  href=\"/templates/pages/troubleshooting-page-template\"",
      "  icon=\"triangle-exclamation\"",
      "  iconType=\"solid\"",
      "  arrow",
      "  horizontal",
      ">",
      "  Link to the main troubleshooting page for this workflow.",
