  "Page Template: [PRODUCT_NAME]": {
    "scope": "mdx,markdown",
    "prefix": "template-solutions-overview-template",
    "body": [
      "---",
      "title: '${1:[PRODUCT_NAME] Title}'",
      "sidebarTitle: '[PRODUCT_NAME] Title'",
      "description: '${2:Describe the page intent and the reader outcome.}'",
      "audience: platform-builder",
      "pageType: overview",
      "purpose: overview",
      "status: current",
      "lastVerified: ${3:YYYY-MM-DD}",
      "keywords:",
      "  - livepeer",
      "  - solutions",
      "  - product-slug",
      "  - overview",
      "'og:image': /snippets/assets/site/og-image/fallback.png",
      "'og:image:alt': Livepeer Docs social preview image",
      "'og:image:type': image/png",
      "'og:image:width': 1200",
      "'og:image:height': 630",
      "---",
      "",
      "import { CustomDivider } from '/snippets/components/elements/spacing/Divider.jsx'",
      "import { CustomCardTitle } from \"/snippets/components/elements/text/Text.jsx\";",
      "import { SocialLinks } from \"/snippets/components/elements/links/Links.jsx\";",
      "import { BorderedBox } from \"/snippets/components/wrappers/containers/Containers.jsx\";",
      "import { CenteredContainer } from \"/snippets/components/wrappers/containers/Containers.jsx\";",
      "import { YouTubeVideo, Video } from \"/snippets/components/displays/video/Video.jsx\";",
      "import { BadgeWrapper, IconBadgeWrapper } from '/snippets/components/wrappers/badges/Badges.jsx'",
      "import { StyledSteps, StyledStep } from '/snippets/components/displays/steps/Steps.jsx'",
      "",
      "export const productBadges = [",
      "  { color: 'blue', label: '[Category Badge]' },",
      "  { color: 'green', label: '[Status Badge]' },",
      "]",
      "",
      "export const productInfra = [",
      "  { icon: 'server', label: '[Infra Tag]' },",
      "  { icon: 'sparkles', label: '[Capability Tag]' },",
      "]",
      "",
      "export const productSocials = [",
      "  { icon: 'globe', href: 'https://__PRODUCT_URL__', label: '[PRODUCT_NAME] Website' },",
      "  { icon: 'github', href: 'https://github.com/__ORG__/__REPO__', label: '[PRODUCT_NAME] GitHub' },",
      "  { icon: 'discord', href: '__DISCORD_URL__', label: '[PRODUCT_NAME] Discord' },",
      "]",
      "",
      "{/*",
      "  BADGES & INFRA TAGS — DO NOT INVENT THESE.",
      "  Copy the exact values from the SolutionCard for this product in v2/solutions/portal.mdx.",
      "  Replace the stub exports above after copying this template into a routable page.",
      "*/}",
      "",
      "<IconBadgeWrapper style={{ margin: \"-1rem 0 1rem 0\" }} iconColor=\"var(--accent)\" size={16} items={productInfra} />",
      "<BadgeWrapper style={{margin: \"0 0 1rem 0\"}} badges={productBadges} />",
      "",
      "{/* socials links */}",
      "<CenteredContainer maxWidth=\"fit-content\">",
      "  <BorderedBox style={{margin: 0, padding: \"0.5rem 1rem 1rem 1rem\"}} variant=\"accent\">",
      "    <SocialLinks iconColor=\"var(--text)\" links={productSocials} />",
      "  </BorderedBox>",
      "</CenteredContainer>",
      "",
      "<Info>",
      "  This page is maintained by the [PRODUCT_NAME] Team. Help & support available via the [PRODUCT_NAME Discord]([DISCORD_URL]).",
      "</Info>",
      "",
      "{/*",
      "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
      "  MEDIA — CHECK ALL OF THESE BEFORE WRITING ANYTHING HERE",
      "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
      "  Sources to check IN ORDER:",
      "    1. snippets/assets/media/videos/         — mp4 files already in repo",
      "    2. community.mdx for this product        — existing YouTubeVideo embeds",
      "    3. Product homepage                      — hero video, demo video",
      "    4. YouTube channel                       — demos, tutorials, conference talks",
      "    5. X / Twitter (@handle)                 — pinned posts, product videos",
      "    6. Bluesky (@handle)                     — especially for web3/AT Protocol products",
      "    7. GitHub README                         — GIFs, screenshots, demo links",
      "",
      "  OPTIONS (use whichever fits):",
      "    <Video src=\"...\" href=\"...\" />                  — mp4 in repo or external URL",
      "    <YouTubeVideo embedUrl=\"...\" title=\"...\" />     — YouTube embed",
      "    <iframe src=\"...\" />                            — embed the product itself (e.g. live dashboard)",
      "    IMAGE/GIF                                       — from README or product site if nothing else",
      "*/}",
      "",
      "<Video src=\"/snippets/assets/media/videos/[product-hero].mp4\" alt=\"[PRODUCT_NAME] Hero Video\" href=\"https://[product-url]\"/>",
      "{/* ALT: <YouTubeVideo embedUrl=\"https://www.youtube.com/embed/[ID]\" title=\"...\" /> */}",
      "{/* ALT: <iframe src=\"https://[product-url]\" width=\"100%\" height=\"600px\" frameBorder=\"0\" allowFullScreen title=\"...\" /> */}",
      "",
      "{/*",
      "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
      "  TWO PARAGRAPHS REQUIRED. DO NOT MERGE. DO NOT SKIP.",
      "  Reference: v2/solutions/daydream/overview.mdx",
      "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
      "",
      "  PARAGRAPH 1 — explains the product (developer audience first):",
      "  What the product IS and what it does for builders.",
      "  Lead with the product name + bold descriptor. 1-2 sentences.",
      "  State concrete capabilities — not \"provides tools to\", not \"enables\".",
      "",
      "  PARAGRAPH 2 — explains connection to Livepeer:",
      "  How this product uses the Livepeer network. 1 sentence.",
      "  Pattern: \"[Product] runs on Livepeer's decentralised GPU network.",
      "  It uses the [X gateway] to route [job type] to the network.\"",
      "*/}",
      "",
      "{/* explains the product */}",
      "[PRODUCT_NAME] is **[bold descriptor]** for [use case]. [What it concretely does for the developer — no filler, no \"provides tools to\".]",
      "",
      "{/* explains connection to Livepeer */}",
      "[PRODUCT_NAME] runs on Livepeer's decentralised GPU network. It uses the [[X] gateway]([GATEWAY_URL]) to route [job type] to the network.",
      "",
      "<CustomDivider style={{margin: \"-0.5rem 0 -2.5rem 0\"}} />",
      "",
      "{/* product features — preferably with a video, embedded content, or blog post */}",
      "## Key Features",
      "- **[Feature 1]** - [One-line description.]",
      "- **[Feature 2]** - [One-line description.]",
      "- **[Feature 3]** - [One-line description.]",
      "- **[Feature 4]** - [One-line description.]",
      "",
      "{/* Remove if no video available */}",
      "<YouTubeVideo",
      "  embedUrl=\"https://www.youtube.com/embed/[VIDEO_ID]\"",
      "  title=\"[Video title]\"",
      "  caption=\"[Caption text]\"",
      "/>",
      "",
      "<CustomDivider style={{margin: \"0 0 -2.5rem 0\"}} />",
      "",
      "{/*",
      "  ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━",
      "  GET STARTED — OPTIONAL. Include if the product has clear",
      "  onboarding steps (try the app, use the API, run infra).",
      "  Use StyledSteps/StyledStep. Reference: daydream/overview.mdx",
