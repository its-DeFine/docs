      "- Style: COLUMN with CARD",
      "- Component: <COLUMNS cols={2}><CARD props: [REQ] title={CUSTOMCARDTITLE(prop: [REQ] title=\"\", [REQ] icon=)}, [REQ]href=\"\" [REQ]horizontal>description</Card></COLUMN>",
