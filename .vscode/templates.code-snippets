      "      </Steps>",
      "    </Tab>",
      "    <Tab title=\"Production\">",
      "      <Steps>",
      "        <Step title=\"Prepare production prerequisites\">",
      "          Document networking, secrets, storage, TLS, monitoring, or chain access requirements for production use.",
      "        </Step>",
      "        <Step title=\"Run the production configuration\">",
      "          Replace this step with the production command, compose file, or deployment workflow.",
