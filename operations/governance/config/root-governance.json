      ],
      "notes": "Ratified AI-first public root artifact."
    },
    {
      "path": "snippets",
      "entry_type": "directory",
      "class": "subsystem_root",
      "owner": "docs",
      "root_basis": "repo_entrypoint",
      "lifecycle": "active",
      "doc_refs": [
        "README.md",
        "snippets/snippets-registry.mdx"
      ],
