        "docs.json",
        "v2/**/*.md",
        "v2/**/*.mdx",
        "operations/scripts/generators/ai/llm/generate-llms-files.js"
      ],
      "public_contract": {
        "url_path": "/llms.txt",
        "purpose": "AI-first text index for LLM consumers."
      },
      "doc_refs": [
        "README.md",
        "docs-guide/features/ai-features.mdx",
        "docs-guide/repo-ops/config/root-governance-map.mdx"
      ],
      "notes": "Ratified AI-first public root artifact. llms-full.txt is retired."
    },
    {
      "path": "operations",
      "entry_type": "directory",
      "class": "subsystem_root",
      "owner": "docs",
      "root_basis": "repo_entrypoint",
      "lifecycle": "active",
      "doc_refs": [
        "README.md"
      ],
      "notes": "Governed scripts, validators, and tests root."
    },
    {
      "path": "robots.txt",
