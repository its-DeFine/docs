      ],
      "notes": "Convenience entrypoint retained at root."
    },
    {
      "path": "README.md",
      "entry_type": "file",
      "class": "repo_entrypoint",
      "owner": "docs",
      "root_basis": "repo_entrypoint",
      "lifecycle": "active",
      "doc_refs": [
        "docs-guide/repo-ops/config/root-governance-map.mdx"
      ],
      "notes": "Repo entrypoint for humans and agents."
    },
    {
      "path": "SECURITY.md",
      "entry_type": "file",
      "class": "platform_contract",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "README.md"
      ],
      "notes": "Security disclosure file remains rooted."
    },
    {
      "path": "ai-tools",
      "entry_type": "directory",
      "class": "subsystem_root",
      "owner": "docs",
      "root_basis": "approved_subsystem",
      "lifecycle": "active",
      "doc_refs": [
        "docs-guide/tooling/ai-tools.mdx",
        "docs-guide/policies/root-allowlist-governance.mdx",
        "README.md"
      ],
      "notes": "Approved root AI-first subsystem. Governance must preserve it at root in this pass."
    },
    {
      "path": "api",
      "entry_type": "directory",
      "class": "subsystem_root",
      "owner": "docs",
      "root_basis": "repo_entrypoint",
      "lifecycle": "active",
      "doc_refs": [
        "README.md"
      ],
      "notes": "API spec root."
    },
    {
      "path": "docs-guide",
      "entry_type": "directory",
      "class": "subsystem_root",
      "owner": "docs",
      "root_basis": "repo_entrypoint",
      "lifecycle": "active",
      "doc_refs": [
        "README.md"
      ],
      "notes": "Canonical internal docs tree."
    },
    {
      "path": "docs-index.json",
      "entry_type": "file",
      "class": "public_artifact",
      "owner": "docs",
      "root_basis": "public_url",
      "lifecycle": "active",
      "generator": "node operations/scripts/generators/content/catalogs/generate-docs-index.js --write",
      "sources": [
        "docs.json",
        "v1/**/*.md",
        "v1/**/*.mdx",
        "v2/**/*.md",
        "v2/**/*.mdx",
        "snippets/**/*.md",
        "snippets/**/*.mdx"
      ],
      "public_contract": {
        "url_path": "/docs-index.json",
        "purpose": "Machine-readable docs inventory for AI and tooling consumers."
      },
      "doc_refs": [
        "README.md",
        "docs-guide/repo-ops/config/root-governance-map.mdx"
      ],
      "notes": "Ratified AI-first public root artifact."
    },
    {
      "path": "docs.json",
      "entry_type": "file",
      "class": "platform_contract",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "README.md",
        "docs-guide/repo-ops/config/repo-config-map.mdx"
      ],
      "notes": "Mintlify routing and navigation source of truth."
    },
    {
