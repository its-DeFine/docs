{
  "version": "root-governance.v1",
  "policy_owner": "docs",
  "generated_outputs": {
    "allowlist": ".allowlist",
    "map_doc": "docs-guide/repo-ops/config/root-governance-map.mdx",
    "sync_report_json": "workspace/reports/repo-ops/ROOT_GOVERNANCE_SYNC_LATEST.json",
    "sync_report_md": "workspace/reports/repo-ops/ROOT_GOVERNANCE_SYNC_LATEST.md"
  },
  "placement_matrix": [
    {
      "surface": "scripts",
      "allowed_paths": [
        "operations/scripts/**",
        "operations/tests/**",
        "tools/**",
        ".githooks/**"
      ],
      "notes": "Executable repo automation belongs in governed script roots, not at repo root."
    },
    {
      "surface": "tooling_docs",
      "allowed_paths": [
        "docs-guide/tooling/**",
        "docs-guide/repo-ops/**",
        "docs-guide/policies/**"
      ],
      "notes": "Human-facing governance and operational docs stay under docs-guide."
    },
    {
      "surface": "public_root_artifacts",
      "allowed_paths": [
        "docs-index.json",
        "llms.txt",
        "sitemap-ai.xml",
        "robots.txt"
      ],
      "notes": "Only explicit public/runtime contracts may remain rooted."
    },
    {
      "surface": "workspace_reports",
      "allowed_paths": [
        "workspace/reports/**"
      ],
      "notes": "Audits, trackers, and generated governance reports belong under workspace/reports."
    },
    {
      "surface": "local_browser_outputs",
      "allowed_paths": [
        "workspace/reports/_local/playwright/**"
      ],
      "notes": "Local-only browser captures must never write to repo root."
    }
  ],
  "local_compatibility": [
    {
      "path": ".env",
      "class": "local_compatibility",
      "tracking_policy": "untracked_only",
      "notes": "Local compatibility env file is tolerated untracked but is never a governed root entry."
    }
  ],
  "forbidden_root_artifacts": [
    {
      "path": ".DS_Store",
      "reason": "OS noise must be cleaned or ignored, never governed."
    },
    {
      "path": ".cache",
      "reason": "Local caches belong in ignored scratch space, not repo root."
    },
    {
      "path": ".cursorrules",
      "reason": "Retired legacy Cursor surface replaced by .cursor/rules/*.mdc."
    },
    {
      "path": ".playwright-cli",
      "reason": "Browser automation output must live under workspace/reports/_local/playwright/."
    },
    {
      "path": "repo-catalog.mdx",
      "reason": "Root placeholder docs are forbidden; governed references belong under docs-guide."
    },
    {
      "path": "ASSISTANT.md",
      "reason": "Legacy assistant root files are retired from the governed root model."
    },
    {
      "path": "Assistant.md",
      "reason": "Legacy assistant root files are retired from the governed root model."
    }
  ],
  "entries": [
    {
      "path": ".allowlist",
      "entry_type": "file",
      "class": "platform_contract",
      "owner": "docs",
      "root_basis": "repo_entrypoint",
      "lifecycle": "active",
      "generator": "node operations/scripts/generators/governance/root/generate-root-governance-artifacts.js --write",
      "sources": [
        "operations/governance/config/root-governance.json",
        "operations/scripts/generators/governance/root/generate-root-governance-artifacts.js",
        "tools/lib/governance/root-governance.js"
      ],
      "doc_refs": [
        "docs-guide/policies/root-allowlist-governance.mdx",
        "docs-guide/repo-ops/config/root-governance-map.mdx"
      ],
      "notes": "Generated projection consumed by the root-structure pre-commit gate."
    },
    {
      "path": ".augment",
      "entry_type": "directory",
      "class": "tool_adapter",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "docs-guide/policies/agent-governance-framework.mdx",
        "docs-guide/tooling/ai-tools.mdx"
      ],
      "notes": "Native Augment adapter root."
    },
    {
      "path": ".claude",
      "entry_type": "directory",
      "class": "tool_adapter",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "docs-guide/policies/agent-governance-framework.mdx",
        "docs-guide/tooling/ai-tools.mdx"
      ],
      "notes": "Native Claude Code adapter root."
    },
    {
      "path": ".codex",
      "entry_type": "directory",
      "class": "tool_adapter",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "AGENTS.md",
        "docs-guide/policies/agent-governance-framework.mdx"
      ],
      "notes": "Codex task-contract and local lock root."
    },
    {
      "path": ".cursor",
      "entry_type": "directory",
      "class": "tool_adapter",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "docs-guide/policies/agent-governance-framework.mdx",
        "docs-guide/tooling/ai-tools.mdx"
      ],
      "notes": "Native Cursor adapter root."
    },
    {
      "path": ".editorconfig",
      "entry_type": "file",
      "class": "docs_runtime",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "README.md"
      ],
      "notes": "Standard repo editor config lives at root for tool discovery."
    },
    {
      "path": ".gitattributes",
      "entry_type": "file",
      "class": "docs_runtime",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "README.md"
      ],
      "notes": "Git attributes are fixed-path root config."
    },
    {
      "path": ".githooks",
      "entry_type": "directory",
      "class": "docs_runtime",
      "owner": "docs",
      "root_basis": "repo_entrypoint",
      "lifecycle": "active",
      "doc_refs": [
        "README.md",
        "docs-guide/policies/root-allowlist-governance.mdx"
      ],
      "notes": "Repo hook root remains rooted because the hook installer and git config expect it."
    },
    {
      "path": ".github",
      "entry_type": "directory",
      "class": "platform_contract",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "README.md",
        "docs-guide/policies/agent-governance-framework.mdx"
      ],
      "notes": "GitHub workflows, issue templates, and Copilot adapter require the fixed root path."
    },
    {
      "path": ".gitignore",
      "entry_type": "file",
      "class": "docs_runtime",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "README.md",
        "docs-guide/policies/root-allowlist-governance.mdx"
      ],
      "notes": "Root ignore policy governs local-only outputs."
    },
    {
      "path": ".mintignore",
      "entry_type": "file",
      "class": "platform_contract",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "README.md",
        "docs-guide/repo-ops/config/repo-config-map.mdx"
      ],
      "notes": "Mintlify build exclusion file is root-discovered."
    },
    {
      "path": ".mintlify",
      "entry_type": "directory",
      "class": "platform_contract",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "docs-guide/policies/agent-governance-framework.mdx",
        "docs-guide/tooling/ai-tools.mdx"
      ],
      "notes": "Mintlify runtime directory remains rooted for the assistant contract."
    },
    {
      "path": ".prettierrc",
      "entry_type": "file",
      "class": "docs_runtime",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "README.md"
      ],
      "notes": "Formatter config is fixed-path root config."
    },
    {
      "path": ".vscode",
      "entry_type": "directory",
      "class": "docs_runtime",
      "owner": "docs",
      "root_basis": "tool_discovery",
      "lifecycle": "active",
      "doc_refs": [
        "README.md"
      ],
      "notes": "Editor workspace settings remain in the conventional root directory."
    },
    {
      "path": ".windsurf",
      "entry_type": "directory",
      "class": "tool_adapter",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "docs-guide/policies/agent-governance-framework.mdx",
        "docs-guide/tooling/ai-tools.mdx"
      ],
      "notes": "Native Windsurf adapter root."
    },
    {
      "path": "AGENTS.md",
      "entry_type": "file",
      "class": "platform_contract",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "docs-guide/policies/agent-governance-framework.mdx",
        "README.md"
      ],
      "notes": "Canonical repo-wide agent baseline."
    },
    {
      "path": "LICENSE",
      "entry_type": "file",
      "class": "platform_contract",
      "owner": "docs",
      "root_basis": "fixed_path",
      "lifecycle": "active",
      "doc_refs": [
        "README.md"
      ],
      "notes": "Repository license stays at root."
    },
    {
      "path": "Makefile",
      "entry_type": "file",
