        "node operations/scripts/generators/governance/reports/generate-repo-governance-status.js --write",
        "node operations/scripts/validators/governance/compliance/check-repo-governance-sync.js --json"
      ],
      "gate_layer": "pr-changed",
      "rollout_state": "migrating",
      "ownerless_ready": false,
      "write_policy": "policy_and_registry_controlled",
      "agent_write_policy": "registry_defaults_only",
      "network_dependent": false,
      "public_contract": "internal",
      "doc_refs": [
        "docs-guide/repo-ops/config/repo-config-map.mdx",
        "docs-guide/policies/governance-index.mdx"
      ],
      "escalation_mode": "human-review-required",
      "success_signals": [
        "github workspace references are explicitly classified",
        "runtime support paths are distinguished from design-only history",
        "repo governance map reflects the current promotion posture"
      ],
      "notes": ".github/workspace contains mixed transitional runtime sources, generated support material, and design/audit history; this classification prevents the whole tree from being treated as canonical runtime governance."
    }
  ]
}
