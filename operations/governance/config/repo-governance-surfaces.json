      "derived_outputs": [
        "docs-index.json",
        "llms.txt",
        "sitemap-ai.xml",
        "docs-guide/repo-ops/config/root-governance-map.mdx",
        "workspace/reports/repo-ops/ROOT_GOVERNANCE_SYNC_LATEST.json",
        "workspace/reports/repo-ops/ROOT_GOVERNANCE_SYNC_LATEST.md",
        "docs-guide/repo-ops/config/repo-governance-map.mdx",
        "workspace/reports/repo-ops/REPO_GOVERNANCE_STATUS_LATEST.json",
        "workspace/reports/repo-ops/REPO_GOVERNANCE_STATUS_LATEST.md"
      ],
      "validators": [
        "operations/tests/unit/generated-artifacts-policy.test.js"
      ],
      "repair_commands": [
        "node operations/scripts/generators/content/catalogs/generate-docs-index.js --write",
        "node operations/scripts/generators/ai/llm/generate-llms-files.js --write",
        "node operations/scripts/generators/content/seo/generate-ai-sitemap.js --write"
      ],
      "gate_layer": "pr-changed",
      "rollout_state": "autofix",
      "ownerless_ready": true,
      "write_policy": "manifest_declared_outputs",
      "agent_write_policy": "generated_only_when_declared",
      "network_dependent": false,
      "public_contract": "public_root_contract",
      "doc_refs": [
        "docs-guide/policies/generated-artifact-and-hook-governance.mdx",
        "docs-guide/repo-ops/config/repo-config-map.mdx"
      ],
      "escalation_mode": "auto-fix-pr",
      "success_signals": [
        "required generated artifacts are declared",
        "artifact classes and policies validate",
        "derived outputs stay current"
      ],
      "notes": "Canonical generated-artifact governance manifest now lives under operations/governance/config while the legacy runtime mirror remains in staged bridge mode."
    },
    {
      "id": "ownerless-governance",
      "name": "Ownerless Governance",
      "surface_type": "ownerless-governance",
      "paths": [
        "operations/governance/config/ownerless-governance-surfaces.json",
        "tools/config/runtime/ownerless-governance-surfaces.json",
        "docs-guide/policies/ownerless-governance.mdx",
        "operations/tests/unit/ownerless-governance.test.js"
      ],
      "canonical_sources": [
        "operations/governance/config/ownerless-governance-surfaces.json",
        "tools/config/runtime/ownerless-governance-surfaces.json",
        "docs-guide/policies/ownerless-governance.mdx"
      ],
      "derived_outputs": [],
      "validators": [
        "operations/tests/unit/ownerless-governance.test.js"
      ],
      "repair_commands": [
        "node operations/scripts/remediators/content/style/repair-ownerless-language.js --write"
      ],
      "gate_layer": "pr-changed",
      "rollout_state": "migrating",
      "ownerless_ready": false,
      "write_policy": "policy_and_registry_controlled",
      "agent_write_policy": "registry_defaults_only",
      "network_dependent": false,
      "public_contract": "internal",
      "doc_refs": [
        "docs-guide/policies/ownerless-governance.mdx"
      ],
      "escalation_mode": "human-review-required",
      "success_signals": [
        "manifest remains structurally valid",
        "policy language stays ownerless",
        "gate-layer contract remains explicit"
      ],
      "notes": "Canonical ownerless-governance manifest now lives under operations/governance/config while the legacy runtime mirror remains in staged bridge mode."
    },
    {
      "id": "github-workspace-governance",
      "name": "GitHub Workspace Governance",
      "surface_type": "github-workspace-governance",
      "paths": [
        ".github/workspace/framework-canonical.md",
        ".github/workspace/decisions-log.mdx",
        ".github/workspace/actions-library",
        ".github/workspace/outcomes.md",
        ".github/workspace/phase2",
        ".github/workspace/design",
