# ═══════════════════════════════════════════════════════════════════════════════
# Livepeer Docs — Environment Variables Reference
# ═══════════════════════════════════════════════════════════════════════════════
#
# COPY this file to the repo root as `.env` (gitignored — never commit real values)
# For CI/CD, configure keys as GitHub Secrets or Variables:
#   Settings → Secrets and variables → Actions
#
# Organized by: concern → output produced → scripts/workflows that consume it
#
# Last updated: 2026-03-23
# ═══════════════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────────────
# CONCERN: social-data
# AREA:    YouTube channel data
# ───────────────────────────────────────────────────────────────────────────────
# Output:  snippets/automations/solutions/{product}/youtubeData.jsx
# Script:  .github/scripts/fetch-youtube-data.js
# GHA:     .github/workflows/update-youtube-data.yml  (weekly, Sun 00:00 UTC)
# CI:      GitHub Secret → YOUTUBE_API_KEY
# ───────────────────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=

# Optional runtime overrides for fetch-youtube-data.js
CHANNEL_ID=UCzfHtZnmUzMbJDxGCwIgY2g   # Default Livepeer channel; overridden per-product by config
PRODUCT_KEY=                            # "daydream" | "livepeer-studio" | "all" | omit for single-channel


# ───────────────────────────────────────────────────────────────────────────────
# CONCERN: social-data
# AREA:    Ghost CMS blog posts
# ───────────────────────────────────────────────────────────────────────────────
# Output:  snippets/automations/blog/ghostBlogData.jsx
#          (Daydream blog data via RSS — no key needed, public feed)
# Script:  .github/scripts/fetch-ghost-blog-data.js
# GHA:     .github/workflows/update-ghost-blog-data.yml  (daily 00:00 UTC)
# CI:      GitHub Secret → GHOST_CONTENT_API_KEY
# Instance: livepeer-studio.ghost.io
# ───────────────────────────────────────────────────────────────────────────────
GHOST_CONTENT_API_KEY=


# ───────────────────────────────────────────────────────────────────────────────
# CONCERN: social-data
# AREA:    Discord announcements channels
# ───────────────────────────────────────────────────────────────────────────────
# Output:  snippets/automations/discord/discordAnnouncementsData.jsx  (global community)
#          snippets/automations/solutions/{product}/discordData.jsx    (per-product)
# Config:  operations/scripts/config/product-social-config.json       (server + channel IDs)
# Script:  .github/scripts/fetch-discord-announcements.js
# GHA:     .github/workflows/update-discord-data.yml  (daily 01:00 UTC)
# CI:      GitHub Secret → DISCORD_BOT_TOKEN
# ───────────────────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=

# OAuth2 application credentials (local dev / admin scripts — NOT used by GHA fetch)
# Only needed if running Discord OAuth flows locally (e.g. user-auth testing)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=


# ───────────────────────────────────────────────────────────────────────────────
# CONCERN: social-data
# AREA:    GitHub Discussions + Releases
# ───────────────────────────────────────────────────────────────────────────────
# Output:  snippets/automations/solutions/{product}/githubDiscussionsData.jsx
#          snippets/automations/solutions/{product}/githubReleasesData.jsx
# Scripts: .github/scripts/fetch-github-discussions.js
#          .github/scripts/fetch-github-releases.js
# GHA:     .github/workflows/update-github-data.yml  (daily 02:00 UTC)
# CI:      Auto-provided by GitHub Actions as secrets.GITHUB_TOKEN (no setup needed)
# Local:   Use a fine-grained PAT — Contents: read, Metadata: read on public repos
# ───────────────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=


# ───────────────────────────────────────────────────────────────────────────────
# CONCERN: showcase
# AREA:    Project showcase pipeline (Google Sheets → JSX data file)
# ───────────────────────────────────────────────────────────────────────────────
# Output:  snippets/automations/showcase/showcaseData.jsx
# Script:  .github/scripts/project-showcase-sync.js
# GHA:     .github/workflows/project-showcase-sync.yml
# CI:      GitHub Secret → SHOWCASE_GOOGLE_SERVICE_ACCOUNT_JSON
#                        → SHOWCASE_DISCORD_BOT_TOKEN
# ───────────────────────────────────────────────────────────────────────────────

# Google Sheets service account JSON (full JSON string — set as GitHub Secret for CI)
SHOWCASE_GOOGLE_SERVICE_ACCOUNT_JSON=

# Google OAuth credentials (local dev auth flow only — not needed for service account in CI)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Separate Discord bot for reviewer notifications (different app from DISCORD_BOT_TOKEN)
SHOWCASE_DISCORD_BOT_TOKEN=

# Non-sensitive showcase config (can also be set as GitHub Variables, not Secrets):
# SHOWCASE_GOOGLE_SHEET_ID=
# SHOWCASE_SUBMISSIONS_SHEET_NAME=Form Responses 1
# SHOWCASE_REVIEW_SHEET_NAME=Review Responses
# SHOWCASE_TRANSFORMED_SHEET_NAME=Transformed Responses
# SHOWCASE_DATA_FILE_PATH=snippets/automations/showcase/showcaseData.jsx
# SHOWCASE_ASSETS_BASE_PATH=snippets/assets/domain/00_HOME/showcase
# SHOWCASE_DISCORD_REVIEWER_USER_ID=
# SHOWCASE_MAX_ROWS_PER_RUN=10


# ───────────────────────────────────────────────────────────────────────────────
# CONCERN: docs-infra
# AREA:    AI-assisted translation
# ───────────────────────────────────────────────────────────────────────────────
# GHA:  .github/workflows/translate-docs.yml
# CI:   GitHub Secret → OPENROUTER_API_KEY
# ───────────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=


# ───────────────────────────────────────────────────────────────────────────────
# CONCERN: docs-infra
# AREA:    SDK generation
# ───────────────────────────────────────────────────────────────────────────────
# GHA:  .github/workflows/sdk_generation.yaml
# CI:   GitHub Secret → SPEAKEASY_API_KEY
# ───────────────────────────────────────────────────────────────────────────────
SPEAKEASY_API_KEY=


# ───────────────────────────────────────────────────────────────────────────────
# CONCERN: local-only
# AREA:    Notion integration (workspace planning scripts)
# ───────────────────────────────────────────────────────────────────────────────
# Scripts: tools/notion/
# Local only — not used in GHA
# See also: tools/notion/.env.example
# ───────────────────────────────────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=


# ───────────────────────────────────────────────────────────────────────────────
# CONCERN: local-only
# AREA:    Fetch script runtime overrides
# ───────────────────────────────────────────────────────────────────────────────
# All fetch scripts (.github/scripts/fetch-*.js) respect these env vars.
# Useful for local testing without modifying config files.
# ───────────────────────────────────────────────────────────────────────────────
# CONFIG_PATH=operations/scripts/config/product-social-config.json
# LIMIT=5


# ═══════════════════════════════════════════════════════════════════════════════
# HOW TO GET EACH KEY — setup instructions with primary source docs
# ═══════════════════════════════════════════════════════════════════════════════
#
# ── YOUTUBE_API_KEY ────────────────────────────────────────────────────────────
#  1. Go to https://console.cloud.google.com/
#  2. Create or select a project.
#  3. Navigate to APIs & Services → Library.
#  4. Search for "YouTube Data API v3" and enable it.
#  5. Go to APIs & Services → Credentials → Create Credentials → API Key.
#  6. Restrict the key to YouTube Data API v3 only (recommended).
#  Docs: https://developers.google.com/youtube/v3/getting-started
#
# ── GHOST_CONTENT_API_KEY ──────────────────────────────────────────────────────
#  1. Go to your Ghost Admin panel (e.g. livepeer-studio.ghost.io/ghost/#/settings)
#  2. Settings → Integrations → Add custom integration.
#  3. Name it (e.g. "Livepeer Docs Fetch"), then copy the Content API Key.
#  Note: Content API Keys are read-only and safe to use in fetch scripts.
#  Docs: https://ghost.org/docs/content-api/
#
# ── DISCORD_BOT_TOKEN ──────────────────────────────────────────────────────────
#  1. Go to https://discord.com/developers/applications
#  2. Create New Application (or open existing "Livepeer Docs Bot" app).
#  3. Go to Bot → Reset Token → copy the token.
#  4. Under Bot → Privileged Gateway Intents, enable "Message Content Intent".
#  5. Invite the bot to your server via OAuth2 → URL Generator with:
#     Scopes: bot | Permissions: Read Messages/View Channels, Read Message History
#  Note: Configure server + channel IDs in product-social-config.json, not here.
#  Docs: https://discord.com/developers/docs/topics/oauth2
#        https://discord.com/developers/docs/reference
#
# ── DISCORD_CLIENT_ID / DISCORD_CLIENT_SECRET ──────────────────────────────────
#  Same Discord Developer application as the bot (OAuth2 tab).
#  1. In your application → OAuth2 → copy Client ID and Client Secret.
#  Only needed for local OAuth2 flows (not required for the bot fetch pipeline).
#  Docs: https://discord.com/developers/docs/topics/oauth2#client-credentials-grant
#
# ── GITHUB_TOKEN ───────────────────────────────────────────────────────────────
#  For CI: automatically provided by GitHub Actions as secrets.GITHUB_TOKEN.
#          No setup needed — GitHub injects it per-run.
#  For local dev:
#  1. Go to https://github.com/settings/tokens?type=beta (Fine-grained PATs)
#  2. Generate new token → select this repository.
#  3. Permissions: Contents: Read-only, Metadata: Read-only.
#  4. Copy the token — it won't be shown again.
#  Docs: https://docs.github.com/en/authentication/keeping-your-account-and-data-secure/managing-your-personal-access-tokens
#
# ── SHOWCASE_GOOGLE_SERVICE_ACCOUNT_JSON ───────────────────────────────────────
#  1. Go to https://console.cloud.google.com/ → IAM & Admin → Service Accounts.
#  2. Create service account → grant "Viewer" role (or custom Sheets read role).
#  3. Keys tab → Add Key → JSON → download.
#  4. Share your Google Sheet with the service account email address.
#  5. Paste the full JSON content as the secret value (newlines included).
#  Docs: https://developers.google.com/sheets/api/guides/authorizing
#        https://cloud.google.com/iam/docs/service-account-overview
#
# ── GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET ────────────────────────────────────
#  For local OAuth2 flows (not needed when service account is configured for CI).
#  1. Go to https://console.cloud.google.com/ → APIs & Services → Credentials.
#  2. Create Credentials → OAuth 2.0 Client IDs → Desktop App.
#  3. Download or copy the client ID and secret.
#  Docs: https://developers.google.com/identity/protocols/oauth2
#
# ── SHOWCASE_DISCORD_BOT_TOKEN ─────────────────────────────────────────────────
#  A separate Discord bot application used exclusively for showcase reviewer
#  notifications. Follow the same steps as DISCORD_BOT_TOKEN above, using a
#  different application in the Discord Developer Portal.
#  Docs: https://discord.com/developers/applications
#
# ── OPENROUTER_API_KEY ─────────────────────────────────────────────────────────
#  1. Go to https://openrouter.ai/keys
#  2. Create an account → Keys → Create Key.
#  3. Copy the key (shown once).
#  Docs: https://openrouter.ai/docs/api-reference
#
# ── SPEAKEASY_API_KEY ──────────────────────────────────────────────────────────
#  1. Go to https://app.speakeasy.com/
#  2. Log in → Settings → API Keys → Generate API Key.
#  Docs: https://www.speakeasy.com/docs/sdk-generation/github-actions
#
# ── NOTION_API_KEY ─────────────────────────────────────────────────────────────
#  1. Go to https://www.notion.so/my-integrations
#  2. New integration → name it → copy the Internal Integration Token.
#  3. In Notion, open the database/page → share with your integration.
#  Docs: https://developers.notion.com/docs/getting-started
#
# ── NOTION_DATABASE_ID ─────────────────────────────────────────────────────────
#  From the database URL: notion.so/{workspace}/{DATABASE_ID}?v=...
#  Copy the UUID segment before the `?v=` query parameter.
#  Docs: https://developers.notion.com/reference/retrieve-a-database
#
# ═══════════════════════════════════════════════════════════════════════════════
