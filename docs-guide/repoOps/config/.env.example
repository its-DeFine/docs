# ============================================================================
# Livepeer Docs — Environment Variables & Secrets Reference
# ============================================================================
#
# This file documents ALL environment variables and secrets used by this repo.
# For CI/CD, configure as GitHub Secrets or Variables
# (Settings → Secrets and variables → Actions).
#
# For local development, copy to the repo root as `.env` (gitignored).
#
# IMPORTANT: Never commit actual secrets.
#
# Last updated: 2026-03-21
# ============================================================================


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  SOLUTIONS SOCIAL DATA AUTOMATIONS                                      ║
# ║  Pipeline: product-social-config.json → fetch scripts → JSX data files  ║
# ║  Config:   tools/scripts/config/product-social-config.json              ║
# ║  Docs:     docs-guide/repoOps/secrets/solutions-secrets.mdx             ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── YouTube Data API ────────────────────────────────────────────────────────
# Script:   .github/scripts/fetch-youtube-data.js
# Workflow: .github/workflows/update-youtube-data.yml (weekly Sun 00:00 UTC)
# Where:    GitHub Secret → YOUTUBE_API_KEY
# Get from: https://console.cloud.google.com/apis/credentials
#           Enable "YouTube Data API v3" in the project.
YOUTUBE_API_KEY=

# Default Livepeer channel. Override per product via product-social-config.json.
CHANNEL_ID=UCzfHtZnmUzMbJDxGCwIgY2g

# Set to a product key (e.g. "daydream") or "all" for multi-channel fetch.
# Omit for legacy single-channel behaviour.
PRODUCT_KEY=

# ── Ghost CMS (Blog) ───────────────────────────────────────────────────────
# Script:   .github/scripts/fetch-ghost-blog-data.js
# Workflow: .github/workflows/update-ghost-blog-data.yml (daily)
# Where:    GitHub Secret → GHOST_CONTENT_API_KEY
# Get from: Ghost Admin → Integrations → Custom integration → Content API Key
#           Instance: livepeer-studio.ghost.io
GHOST_CONTENT_API_KEY=

# ── Discord Bot ─────────────────────────────────────────────────────────────
# Script:   .github/scripts/fetch-discord-announcements.js
# Workflow: .github/workflows/update-discord-data.yml (daily 01:00 UTC)
# Where:    GitHub Secret → DISCORD_BOT_TOKEN
# Get from: https://discord.com/developers/applications
#           Create application → Bot → Token. Bot needs "Read Message History"
#           permission in the target announcements channel(s).
#           Configure server/channel IDs in product-social-config.json.
DISCORD_BOT_TOKEN=

# ── GitHub Discussions & Releases ───────────────────────────────────────────
# Scripts:  .github/scripts/fetch-github-discussions.js
#           .github/scripts/fetch-github-releases.js
# Workflow: .github/workflows/update-github-data.yml (daily 02:00 UTC)
# Where:    Auto-provided by GitHub Actions as secrets.GITHUB_TOKEN
#           For local dev, use a fine-grained PAT with public_repo read access.
# Get from: https://github.com/settings/tokens (Fine-grained → public repos, read-only)
GITHUB_TOKEN=

# ── RSS Blog Feeds ──────────────────────────────────────────────────────────
# Script:   .github/scripts/fetch-rss-blog-data.js
# Workflow: .github/workflows/update-rss-blog-data.yml (daily 03:00 UTC)
# Where:    No secret needed — fetches public RSS feeds.
# Config:   Blog RSS URLs in product-social-config.json


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  DOCS INFRASTRUCTURE                                                     ║
# ║  Core repo operations: auto-commit PATs, translation, SDK generation     ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Docs v2 PAT (auto-commit) ──────────────────────────────────────────────
# Workflows: update-ghost-blog-data.yml, update-forum-data.yml
# Where:     GitHub Secret → DOCS_V2
# Purpose:   Personal Access Token with write access for auto-committing data
#            updates. Needed because GITHUB_TOKEN cannot trigger other workflows.
# Get from:  https://github.com/settings/tokens (Classic → repo scope)
DOCS_V2=

# ── OpenRouter (Translation) ───────────────────────────────────────────────
# Workflow: .github/workflows/translate-docs.yml
# Where:    GitHub Secret → OPENROUTER_API_KEY
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Speakeasy (SDK Generation) ─────────────────────────────────────────────
# Workflow: .github/workflows/sdk_generation.yaml
# Where:    GitHub Secret → SPEAKEASY_API_KEY
# Get from: https://app.speakeasy.com/ → Settings → API Keys
SPEAKEASY_API_KEY=


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  PROJECT SHOWCASE PIPELINE                                               ║
# ║  Google Sheets → GitHub → Discord notification flow                      ║
# ║  Script:   .github/scripts/project-showcase-sync.js                     ║
# ║  Workflow: .github/workflows/project-showcase-sync.yml                  ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# Secrets (GitHub Secrets):
SHOWCASE_GOOGLE_SERVICE_ACCOUNT_JSON=    # JSON key for Google Sheets API service account
SHOWCASE_DISCORD_BOT_TOKEN=              # Separate bot token for showcase notifications

# Variables (GitHub Variables — not secrets, non-sensitive config):
# SHOWCASE_GOOGLE_SHEET_ID=              # Google Sheet ID
# SHOWCASE_SUBMISSIONS_SHEET_NAME=       # Default: "Form Responses 1"
# SHOWCASE_SUBMISSIONS_SHEET_URL=        # URL for the submissions form
# SHOWCASE_REVIEW_SHEET_NAME=            # Default: "Review Responses"
# SHOWCASE_TRANSFORMED_SHEET_NAME=       # Default: "Transformed Responses"
# SHOWCASE_REVIEW_PROCESSED_COLUMN=      # Default: "Processed"
# SHOWCASE_APPROVAL_FORM_BASE_URL=       # Base URL for approval form
# SHOWCASE_GITHUB_OWNER=                 # Default: repo owner
# SHOWCASE_GITHUB_REPO=                  # Default: repo name
# SHOWCASE_GITHUB_DATA_BRANCH=           # Default: "docs-v2-preview"
# SHOWCASE_GITHUB_ASSETS_BRANCH=         # Default: "docs-v2-assets"
# SHOWCASE_DATA_FILE_PATH=               # Default: "snippets/automations/showcase/showcaseData.jsx"
# SHOWCASE_ASSETS_BASE_PATH=             # Default: "snippets/assets/domain/00_HOME/showcase"
# SHOWCASE_DISCORD_REVIEWER_USER_ID=     # Discord user ID for review notifications
# SHOWCASE_DISCORD_API_BASE_URL=         # Default: "https://discord.com/api/v10"
# SHOWCASE_MAX_ROWS_PER_RUN=             # Default: 10


# ╔═══════════════════════════════════════════════════════════════════════════╗
# ║  LOCAL-ONLY TOOLING                                                      ║
# ║  Not used in CI — local development scripts only                         ║
# ╚═══════════════════════════════════════════════════════════════════════════╝

# ── Notion ──────────────────────────────────────────────────────────────────
# Used by:  tools/notion/ scripts
# Get from: https://www.notion.so/my-integrations
# See also: tools/notion/.env.example
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Fetch script overrides ─────────────────────────────────────────────────
# Config path (all fetch scripts default to tools/scripts/config/product-social-config.json)
# CONFIG_PATH=tools/scripts/config/product-social-config.json

# Limit override for fetch scripts (controls how many items to fetch)
# LIMIT=5
