#!/bin/bash
# Pre-commit hook to enforce style guide compliance
# Checks for common violations before allowing commits
#
# To install this hook, run:
#   cp .githooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# Bypass flags (use sparingly):
#   SKIP_STRUCTURE_CHECK=1 - Skip root directory and snippets structure checks
#   SKIP_STYLE_CHECK=1     - Skip style guide compliance checks
#   SKIP_VERIFICATION=1    - Skip verification scripts
#   SKIP_TESTS=1           - Skip test suite
#   SKIP_ALL=1             - Skip all checks (use with extreme caution)
#
# Human-only override flags:
#   ALLOW_WHITELIST_EDIT=1 - Allow editing .whitelist file (HUMANS ONLY - AIs must never use this)
#   ALLOW_DELETIONS=1      - Allow file deletions (HUMANS ONLY - AIs must never use this)

STYLE_GUIDE_PATH="v2/pages/07_resources/documentation-guide/style-guide.mdx"
VIOLATIONS=0
WARNINGS=()

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Check for bypass flags
SKIP_STRUCTURE_CHECK=${SKIP_STRUCTURE_CHECK:-0}
SKIP_STYLE_CHECK=${SKIP_STYLE_CHECK:-0}
SKIP_VERIFICATION=${SKIP_VERIFICATION:-0}
SKIP_TESTS=${SKIP_TESTS:-0}
SKIP_ALL=${SKIP_ALL:-0}
ALLOW_DELETIONS=${ALLOW_DELETIONS:-0}

if [ "$SKIP_ALL" = "1" ]; then
    echo -e "${YELLOW}вљ пёЏ  WARNING: All pre-commit checks bypassed (SKIP_ALL=1)${NC}"
    echo -e "${YELLOW}   This should only be used in emergencies.${NC}"
    exit 0
fi

# Check for file deletions (BLOCKED - requires human override)
# NOTE: Deletions in tasks/ are allowed (AI-only working directory)
ALL_DELETED_FILES=$(git diff --cached --name-only --diff-filter=D || true)
DELETED_FILES=$(echo "$ALL_DELETED_FILES" | grep -v '^tasks/' || true)

if [ -n "$DELETED_FILES" ]; then
    if [ "$ALLOW_DELETIONS" != "1" ]; then
        VIOLATIONS=$((VIOLATIONS + 1))
        echo -e "${RED}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
        echo -e "${RED}в•‘  вќЊ FILE DELETIONS DETECTED - COMMIT BLOCKED                 в•‘${NC}"
        echo -e "${RED}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
        echo ""
        echo -e "${RED}рџљ« DELETIONS ARE NOT ALLOWED${NC}"
        echo ""
        echo "The following files are being deleted:"
        echo "$DELETED_FILES" | sed 's/^/  вќЊ /'
        echo ""
        if [ -n "$(echo "$ALL_DELETED_FILES" | grep '^tasks/')" ]; then
            echo -e "${GREEN}в„№пёЏ  Note: Deletions in tasks/ are allowed (AI-only working directory)${NC}"
            echo ""
        fi
        echo -e "${YELLOW}рџ“‹ INSTRUCTIONS FOR AI AGENTS:${NC}"
        echo ""
        echo -e "${YELLOW}  вљ пёЏ  DO NOT DELETE FILES - DETERMINE CORRECT LOCATION INSTEAD${NC}"
        echo ""
        echo "  1. READ THE FILES to understand their content and purpose"
        echo "  2. CHECK THE MIGRATION PLAN: tasks/plan/migration-plan.md"
        echo "  3. CHECK THE README: README.md (source of truth for structure)"
        echo "  4. CHECK THE WHITELIST: .whitelist (allowed root files)"
        echo "  5. DETERMINE CORRECT LOCATION based on file content and structure rules"
        echo "  6. MOVE files to correct location using 'git mv' (NOT delete+add)"
        echo ""
        echo -e "${YELLOW}рџ“‹ CORRECT LOCATIONS (per migration plan):${NC}"
        echo "  - Config files в†’ tools/config/ (EXCEPT .prettierrc.yaml в†’ ROOT)"
        echo "  - .prettierrc.yaml в†’ ROOT (Prettier convention)"
        echo "  - .speakeasy/ в†’ tools/config/.speakeasy/ (Speakeasy API docs tool config)"
        echo "  - AI rules в†’ tools/ai-rules/"
        echo "  - Scripts в†’ tools/scripts/ (organized by purpose)"
        echo "  - Planning docs в†’ tasks/plan/"
        echo "  - Reports в†’ tasks/reports/"
        echo "  - API specs в†’ api/"
        echo "  - Contribution docs в†’ contribute/"
        echo "  - Assets в†’ snippets/assets/site/"
        echo ""
        echo -e "${YELLOW}рџ“‹ FOR HUMANS:${NC}"
        echo "  1. If you need to move files, use 'git mv' instead of delete+add"
        echo "  2. If files should be removed, unstage them: 'git restore --staged <file>'"
        echo "  3. If this deletion is intentional and necessary:"
        echo "     - Document WHY in the commit message"
        echo "     - Verify files are backed up"
        echo "     - Use: ALLOW_DELETIONS=1 git commit"
        echo ""
        echo -e "${RED}вљ пёЏ  HUMAN OVERRIDE: Set ALLOW_DELETIONS=1 to allow deletions${NC}"
        echo -e "${RED}   (AIs must NEVER use this flag - deletions are dangerous!)${NC}"
        echo ""
    else
        echo -e "${YELLOW}вљ пёЏ  WARNING: File deletions allowed (ALLOW_DELETIONS=1)${NC}"
        echo -e "${YELLOW}   Make sure deletions are intentional and files are backed up!${NC}"
    fi
fi

# Check for .whitelist file changes (BLOCKED for AIs, requires human override)
WHITELIST_CHANGES=$(git diff --cached --name-only | grep -E '^\.whitelist$|^\.whitelist ' || true)
if [ -n "$WHITELIST_CHANGES" ]; then
    ALLOW_WHITELIST_EDIT=${ALLOW_WHITELIST_EDIT:-0}
    if [ "$ALLOW_WHITELIST_EDIT" != "1" ]; then
        VIOLATIONS=$((VIOLATIONS + 1))
        echo -e "${RED}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
        echo -e "${RED}в•‘  .whitelist FILE CHANGES BLOCKED                              в•‘${NC}"
        echo -e "${RED}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
        echo ""
        echo -e "${RED}Attempted changes to .whitelist:${NC}"
        echo -e "${RED}  вќЊ .whitelist${NC}"
        echo ""
        echo -e "${YELLOW}вљ пёЏ  CRITICAL: .whitelist file is protected.${NC}"
        echo -e "${YELLOW}   The .whitelist file contains the rule:${NC}"
        echo -e "${YELLOW}   'IF YOU ARE AN AI YOU ARE ABSOLUTELY NOT ALLOWED TO EDIT THIS FILE.'${NC}"
        echo ""
        echo -e "${YELLOW}To allow editing .whitelist (HUMANS ONLY):${NC}"
        echo -e "${YELLOW}  ALLOW_WHITELIST_EDIT=1 git commit -m \"your message\"${NC}"
        echo ""
        echo -e "${RED}Commit blocked. Only humans may edit .whitelist with explicit override.${NC}"
        echo ""
        exit 1
    else
        echo -e "${YELLOW}вљ пёЏ  WARNING: .whitelist edit allowed (ALLOW_WHITELIST_EDIT=1)${NC}"
        echo -e "${YELLOW}   This flag should ONLY be used by humans, never by AI agents.${NC}"
    fi
fi

# Check root directory structure against whitelist
if [ "$SKIP_STRUCTURE_CHECK" = "1" ]; then
    echo -e "${YELLOW}вљ пёЏ  Structure checks bypassed (SKIP_STRUCTURE_CHECK=1)${NC}"
else
    echo -e "${YELLOW}рџ”Ќ Checking root directory structure...${NC}"

    if [ ! -f ".whitelist" ]; then
        echo -e "${YELLOW}вљ пёЏ  .whitelist file not found, skipping root structure check${NC}"
    else
    # Read whitelist (skip comments and empty lines)
    WHITELIST=$(grep -v '^#' .whitelist | grep -v '^$' | tr '\n' '|' | sed 's/|$//')
    
    if [ -z "$WHITELIST" ]; then
        echo -e "${YELLOW}вљ пёЏ  .whitelist is empty, skipping root structure check${NC}"
    else
        # Check for new root files (not in whitelist)
        NEW_ROOT_FILES=$(git diff --cached --name-only --diff-filter=A | grep -E '^[^/]+$' | grep -vE "^($WHITELIST)$" || true)
        
        # Check for new root directories (not in whitelist)
        NEW_ROOT_DIRS=$(git diff --cached --name-only --diff-filter=A | grep -E '^[^/]+/' | cut -d'/' -f1 | sort -u | grep -vE "^($WHITELIST)$" || true)
        
        if [ -n "$NEW_ROOT_FILES" ] || [ -n "$NEW_ROOT_DIRS" ]; then
            VIOLATIONS=$((VIOLATIONS + 1))
            echo -e "${RED}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
            echo -e "${RED}в•‘  UNAUTHORIZED ROOT FILES/DIRECTORIES DETECTED               в•‘${NC}"
            echo -e "${RED}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
            echo ""
            
            if [ -n "$NEW_ROOT_FILES" ]; then
                echo -e "${RED}Unauthorized root files:${NC}"
                while IFS= read -r file; do
                    if [ -n "$file" ]; then
                        echo -e "${RED}  вќЊ $file${NC}"
                        WARNINGS+=("вќЊ Unauthorized root file: $file")
                    fi
                done < <(echo "$NEW_ROOT_FILES")
                echo ""
            fi
            
            if [ -n "$NEW_ROOT_DIRS" ]; then
                echo -e "${RED}Unauthorized root directories:${NC}"
                while IFS= read -r dir; do
                    if [ -n "$dir" ]; then
                        echo -e "${RED}  вќЊ $dir/${NC}"
                        WARNINGS+=("вќЊ Unauthorized root directory: $dir/")
                    fi
                done < <(echo "$NEW_ROOT_DIRS")
                echo ""
            fi
            
            echo -e "${YELLOW}Allowed root files/directories are listed in .whitelist${NC}"
            echo -e "${YELLOW}See contribute/STRUCTURE.md for repository structure rules${NC}"
            echo ""
        else
            echo -e "${GREEN}вњ“ Root directory structure check passed${NC}"
        fi
    fi
    fi
fi

# Check snippets directory structure
if [ "$SKIP_STRUCTURE_CHECK" = "1" ]; then
    echo -e "${YELLOW}вљ пёЏ  Snippets structure checks bypassed${NC}"
else
    echo ""
    echo -e "${YELLOW}рџ”Ќ Checking snippets directory structure...${NC}"

    STAGED_SNIPPETS=$(git diff --cached --name-only --diff-filter=A | grep '^snippets/')

    if [ -n "$STAGED_SNIPPETS" ]; then
    # Check for scripts in snippets/
    SNIPPETS_SCRIPTS=$(echo "$STAGED_SNIPPETS" | grep '^snippets/scripts/')
    if [ -n "$SNIPPETS_SCRIPTS" ]; then
        VIOLATIONS=$((VIOLATIONS + 1))
        echo -e "${RED}вќЊ Scripts cannot be in snippets/. Move to tools/scripts/${NC}"
        echo "$SNIPPETS_SCRIPTS" | while read -r file; do
            WARNINGS+=("вќЊ $file: Scripts must be in tools/scripts/, not snippets/")
        done
    fi
    
    # Check for wiki/docs in snippets/
    SNIPPETS_WIKI=$(echo "$STAGED_SNIPPETS" | grep '^snippets/snippetsWiki/')
    if [ -n "$SNIPPETS_WIKI" ]; then
        VIOLATIONS=$((VIOLATIONS + 1))
        echo -e "${RED}вќЊ Wiki/docs cannot be in snippets/. Move to tools/wiki/${NC}"
        echo "$SNIPPETS_WIKI" | while read -r file; do
            WARNINGS+=("вќЊ $file: Wiki must be in tools/wiki/, not snippets/")
        done
    fi
    
    # Check for styles in snippets/
    SNIPPETS_STYLES=$(echo "$STAGED_SNIPPETS" | grep '^snippets/styles/')
    if [ -n "$SNIPPETS_STYLES" ]; then
        VIOLATIONS=$((VIOLATIONS + 1))
        echo -e "${RED}вќЊ Styles cannot be in snippets/. Use root style.css only${NC}"
        echo "$SNIPPETS_STYLES" | while read -r file; do
            WARNINGS+=("вќЊ $file: Styles must use root style.css, not snippets/styles/")
        done
    fi
    fi
fi

# Check for changes to v1/ (frozen)
if [ "$SKIP_STRUCTURE_CHECK" = "1" ]; then
    echo -e "${YELLOW}вљ пёЏ  v1/ frozen check bypassed${NC}"
else
    echo ""
    echo -e "${YELLOW}рџ”Ќ Checking v1/ directory (frozen)...${NC}"

    V1_CHANGES=$(git diff --cached --name-only | grep '^v1/')
    if [ -n "$V1_CHANGES" ]; then
        VIOLATIONS=$((VIOLATIONS + 1))
        echo -e "${RED}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
        echo -e "${RED}в•‘  v1/ IS FROZEN - NO CHANGES ALLOWED                        в•‘${NC}"
        echo -e "${RED}в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ${NC}"
        echo ""
        echo -e "${RED}Attempted changes to v1/:${NC}"
        echo "$V1_CHANGES" | while read -r file; do
            echo -e "${RED}  вќЊ $file${NC}"
            WARNINGS+=("вќЊ $file: v1/ is FROZEN - no changes allowed")
        done
        echo ""
        echo -e "${RED}Commit blocked. v1/ is immutable and cannot be modified.${NC}"
        echo ""
        exit 1
    else
        echo -e "${GREEN}вњ“ v1/ directory check passed (no changes detected)${NC}"
    fi
fi

# Check style guide compliance
if [ "$SKIP_STYLE_CHECK" = "1" ]; then
    echo -e "${YELLOW}вљ пёЏ  Style guide checks bypassed (SKIP_STYLE_CHECK=1)${NC}"
else
    echo ""
    echo -e "${YELLOW}рџ”Ќ Checking style guide compliance...${NC}"

    # Get list of staged files (excluding style-guide.mdx which documents examples of what NOT to do)
    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(jsx|tsx|js|mdx)$' | grep -v "style-guide")

    if [ -z "$STAGED_FILES" ]; then
        echo -e "${GREEN}вњ“ No JSX/TSX/MDX files staged, skipping style checks${NC}"
    else

        # Check 1: ThemeData import/usage (DEPRECATED)
        echo "Checking for ThemeData usage (deprecated)..."
        for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # Skip if it's the style guide itself (it documents ThemeData as deprecated)
        if [[ "$file" == *"style-guide.mdx" ]]; then
            continue
        fi
        if grep -q "ThemeData\|themeStyles\.jsx" "$file" 2>/dev/null; then
            WARNINGS+=("вќЊ $file: Uses deprecated ThemeData - use CSS Custom Properties instead")
            VIOLATIONS=$((VIOLATIONS + 1))
        fi
        fi
    done

    # Check 2: Hardcoded hex colors that should use CSS variables
    echo "Checking for hardcoded colors..."
    for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # Skip style guide (it documents colors in tables)
        if echo "$file" | grep -q "style-guide.mdx"; then
            continue
        fi
        # Check for common Livepeer colors hardcoded (should use CSS vars)
        # Exclude markdown tables and code examples
        if grep -E "(#3CB540|#2b9a66|#18794E|#181C18|#E0E4E0|#717571|#A0A4A0)" "$file" 2>/dev/null | grep -v "var(--" | grep -v "CSS Custom Properties" | grep -v "style-guide" | grep -v "Color System" | grep -v "Light Mode\|Dark Mode" | grep -v '^|' | grep -v '^```' > /dev/null; then
            WARNINGS+=("вљ пёЏ  $file: Contains hardcoded theme colors - use CSS Custom Properties (var(--accent), etc.)")
            VIOLATIONS=$((VIOLATIONS + 1))
        fi
        fi
    done

    # Check 3: Relative imports (should be absolute from root)
    echo "Checking for relative imports..."
    for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # Skip style guide (it documents relative imports as examples of what NOT to do)
        if [[ "$file" == *"style-guide"* ]]; then
            continue
        fi
        if grep -E "from ['\"].*\.\./.*['\"]" "$file" 2>/dev/null | grep -v "node_modules" | grep -v "\.\./\.\./\.\." | grep -v "examples/" > /dev/null; then
            WARNINGS+=("вљ пёЏ  $file: Uses relative imports - use absolute paths from root (/snippets/...)")
            VIOLATIONS=$((VIOLATIONS + 1))
        fi
        fi
    done

    # Check 4: Import from @mintlify/components (should not import, they're global)
    echo "Checking for @mintlify/components imports..."
    for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # Skip style guide (it documents this as a "don't do this" example)
        if [[ "$file" == *"style-guide.mdx" ]]; then
            continue
        fi
        if grep -q "from ['\"]@mintlify/components['\"]" "$file" 2>/dev/null; then
            WARNINGS+=("вљ пёЏ  $file: Imports from @mintlify/components - these are global, no import needed")
            VIOLATIONS=$((VIOLATIONS + 1))
        fi
        fi
    done

    # Check 5: React imports (hooks are global in Mintlify)
    echo "Checking for unnecessary React imports..."
    for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        # Skip style guide (it documents this as a "don't do this" example)
        if [[ "$file" == *"style-guide.mdx" ]]; then
            continue
        fi
        if grep -E "import.*\{.*useState|useEffect|useMemo|useCallback.*\}.*from ['\"]react['\"]" "$file" 2>/dev/null; then
            WARNINGS+=("вљ пёЏ  $file: Imports React hooks - hooks are global in Mintlify, no import needed")
            VIOLATIONS=$((VIOLATIONS + 1))
        fi
    fi
    done
    fi
fi

# Run verification scripts
if [ "$SKIP_VERIFICATION" = "1" ]; then
    echo -e "${YELLOW}вљ пёЏ  Verification scripts bypassed (SKIP_VERIFICATION=1)${NC}"
else
    echo ""
    echo -e "${YELLOW}в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ${NC}"
    echo -e "${YELLOW}Running verification scripts...${NC}"
    if [ -f ".githooks/verify.sh" ]; then
        if bash .githooks/verify.sh; then
            echo -e "${GREEN}вњ“ Verification scripts passed${NC}"
        else
            VERIFY_EXIT=$?
            if [ $VERIFY_EXIT -ne 0 ]; then
                VIOLATIONS=$((VIOLATIONS + 1))
                WARNINGS+=("вќЊ Verification scripts failed - see output above")
            fi
        fi
    else
        echo -e "${YELLOW}вљ пёЏ  Verification script not found, skipping...${NC}"
    fi
