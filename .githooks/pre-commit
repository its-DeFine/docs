#!/bin/bash
# @script            pre-commit
# @category          orchestrator
# @purpose           infrastructure:pipeline-orchestration
# @scope             .githooks
# @domain            docs
# @needs             R-R29
# @purpose-statement Pre-commit hook — hard gates only (syntax, security, safety). All soft checks run in GitHub Actions PR workflows.
# @pipeline          P1 (commit, hook entry point)
# @usage             bash .githooks/pre-commit [flags]
#
# HARD GATES ONLY — this hook blocks commits that would:
#   1. Break MDX syntax (unparseable pages)
#   2. Break docs.json redirect integrity
#   3. Delete files without human override
#   4. Modify .allowlist or v1/ (frozen/protected)
#   5. Violate Codex branch isolation
#
# Everything else (style, copy, components, governance, indexes, catalogs)
# runs in GitHub Actions workflows on pull_request events.
#
# To install this hook, run:
#   bash .githooks/install.sh
#   # or: lpd hooks install
#
# Bypass flags (use sparingly):
#   SKIP_STRUCTURE_CHECK=1 - Skip root directory structure checks
#   SKIP_ALL=1             - Skip all checks (use with extreme caution)
#
# Human-only override flags:
#   --trailer "allowlist-edit=true"   - Allow editing .allowlist file (HUMANS ONLY)
#   --trailer "allow-deletions=true"  - Allow file deletions (HUMANS ONLY)
#   --trailer "allow-main-commit=true" - Allow codex session to commit to docs-v2

VIOLATIONS=0
WARNINGS=()

# Colors for output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m' # No Color

# Check for bypass flags
SKIP_STRUCTURE_CHECK=${SKIP_STRUCTURE_CHECK:-0}
SKIP_ALL=${SKIP_ALL:-0}
ALLOW_DELETIONS=${ALLOW_DELETIONS:-0}
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")

# Freeze staged files snapshot
STAGED_FILES_SNAPSHOT=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null || true)
STAGED_FILES_SNAPSHOT_DELETED=$(git diff --cached --name-only --diff-filter=D 2>/dev/null || true)

# ═══════════════════════════════════════════════════════════════
# HELPER FUNCTIONS
# ═══════════════════════════════════════════════════════════════

PARENT_GIT_CMD=$(ps -o command= -p "$PPID" 2>/dev/null || true)

has_human_override_trailer() {
    local trailer_key="$1"
    case "$PARENT_GIT_CMD" in
        *"--trailer ${trailer_key}"*|*"--trailer=${trailer_key}"*|*"--trailer \"${trailer_key}"*|*"--trailer '${trailer_key}"*)
            return 0
            ;;
    esac
    return 1
}

is_codex_session() {
    if [[ "${CODEX_SHELL:-0}" == "1" ]]; then return 0; fi
    if [[ -n "${CODEX_THREAD_ID:-}" ]]; then return 0; fi
    if [[ "${CODEX_CI:-0}" == "1" ]]; then return 0; fi
    if [[ -n "${CODEX_INTERNAL_ORIGINATOR_OVERRIDE:-}" ]]; then return 0; fi
    return 1
}

allow_docs_v2_commit_override() {
    if [[ "${ALLOW_MAIN_COMMIT:-0}" == "1" ]]; then return 0; fi
    if has_human_override_trailer "allow-main-commit=true"; then return 0; fi
    return 1
}

get_git_blob_ref() {
    local object_ref="$1"
    git rev-parse --verify "$object_ref" 2>/dev/null || true
}

get_archive_followup_target() {
    local file_path="$1"
    if [[ "$file_path" != v2/* ]]; then return 1; fi
    if [[ "$file_path" == v2/x-archived/* ]]; then return 1; fi
    printf 'v2/x-archived/%s\n' "${file_path#v2/}"
}

is_allowed_archive_followup_delete() {
    local file_path="$1"
    local archive_path=""
    local source_blob=""
    local archive_blob=""
    archive_path=$(get_archive_followup_target "$file_path") || return 1
    source_blob=$(get_git_blob_ref "HEAD:$file_path")
    if [ -z "$source_blob" ]; then return 1; fi
    archive_blob=$(get_git_blob_ref ":$archive_path")
    if [ -z "$archive_blob" ]; then
        archive_blob=$(get_git_blob_ref "HEAD:$archive_path")
    fi
    if [ -z "$archive_blob" ]; then return 1; fi
    [ "$source_blob" = "$archive_blob" ]
}

# ═══════════════════════════════════════════════════════════════
# SKIP_ALL BYPASS
# ═══════════════════════════════════════════════════════════════

if [ "$SKIP_ALL" = "1" ]; then
    echo -e "${YELLOW}⚠️  WARNING: All pre-commit checks bypassed (SKIP_ALL=1)${NC}"
    echo -e "${YELLOW}   This should only be used in emergencies.${NC}"
    exit 0
fi

# ═══════════════════════════════════════════════════════════════
# HARD GATE 1: CODEX BRANCH ISOLATION
# ═══════════════════════════════════════════════════════════════

enforce_docs_v2_codex_isolation() {
    if [[ "$CURRENT_BRANCH" != "docs-v2" ]]; then return 0; fi
    if ! is_codex_session; then return 0; fi
    if allow_docs_v2_commit_override; then
        echo -e "${YELLOW}⚠️  docs-v2 commit override detected (human-authorized).${NC}"
        return 0
    fi
    echo -e "${RED}╔═══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║  ❌ COMMIT BLOCKED: CODEX SESSION ON docs-v2                 ║${NC}"
    echo -e "${RED}╚═══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${YELLOW}Do not stash/reset. Preserve current staged+unstaged edits by branching in-place:${NC}"
    echo "  git switch -c codex/<issue-id>-<slug>"
    echo ""
    echo -e "${YELLOW}Then initialize contract + lock:${NC}"
    echo "  node tools/scripts/dispatch/governance/codex/task-preflight.js --task <issue-id> --slug <slug> --scope \"<path1,path2>\""
    echo ""
    echo -e "${YELLOW}Human override (explicit chat instruction required):${NC}"
    echo "  ALLOW_MAIN_COMMIT=1 git commit -m \"...\" --trailer \"allow-main-commit=true\""
    echo ""
    return 1
}

if ! enforce_docs_v2_codex_isolation; then
    exit 1
fi

if [[ "$CURRENT_BRANCH" == "docs-v2" ]]; then
    echo -e "${YELLOW}⚠️  You are committing on docs-v2. Recommended path for agent tasks is an isolated codex/<issue-id>-<slug> branch/worktree.${NC}"
fi

# Codex task contract check
if [[ "$CURRENT_BRANCH" == codex/* ]]; then
    echo -e "${YELLOW}🔍 Validating codex task contract...${NC}"
    if node tools/scripts/validators/governance/compliance/validate-codex-task-contract.js --branch "$CURRENT_BRANCH" --validate-contract-only --quiet 2>/dev/null; then
        echo -e "${GREEN}✓ Codex task contract check passed${NC}"
    else
        VIOLATIONS=$((VIOLATIONS + 1))
        WARNINGS+=("❌ Codex task contract validation failed")
        echo -e "${RED}❌ Codex task contract validation failed${NC}"
    fi

    # Codex lock check
    local_lock_script="tools/scripts/dispatch/governance/codex/validate-locks.js"
    if [ -f "$local_lock_script" ]; then
        echo -e "${YELLOW}🔍 Validating codex local lock ownership...${NC}"
        if node "$local_lock_script" --branch "$CURRENT_BRANCH" --staged --quiet 2>/dev/null; then
            echo -e "${GREEN}✓ Codex local lock check passed${NC}"
        else
            VIOLATIONS=$((VIOLATIONS + 1))
            WARNINGS+=("❌ Codex local lock validation failed")
            echo -e "${RED}❌ Codex local lock validation failed${NC}"
        fi
    fi

    # AI stash policy
    stash_script="tools/scripts/dispatch/governance/codex/check-no-ai-stash.sh"
    if [ -x "$stash_script" ]; then
        echo -e "${YELLOW}🔍 Enforcing AI stash policy...${NC}"
        if bash "$stash_script" --quiet 2>/dev/null; then
            echo -e "${GREEN}✓ AI stash policy check passed${NC}"
        else
            VIOLATIONS=$((VIOLATIONS + 1))
            WARNINGS+=("❌ AI stash policy violation")
            echo -e "${RED}❌ AI stash policy violation: stash-based isolation detected${NC}"
        fi
    fi
fi

# ═══════════════════════════════════════════════════════════════
# HARD GATE 2: FILE DELETION GUARD
# ═══════════════════════════════════════════════════════════════

ALL_DELETED_FILES=$(git diff --cached --name-only --diff-filter=D || true)
DELETED_FILES=$(echo "$ALL_DELETED_FILES" | grep -v '^tasks/' || true)
ALLOWED_ARCHIVE_DELETIONS=""

if [ -n "$DELETED_FILES" ]; then
    FILTERED_DELETED_FILES=""
    while IFS= read -r deleted_file; do
        if [ -z "$deleted_file" ]; then continue; fi
        if is_allowed_archive_followup_delete "$deleted_file"; then
            ALLOWED_ARCHIVE_DELETIONS="${ALLOWED_ARCHIVE_DELETIONS}${deleted_file}"$'\n'
            continue
        fi
        FILTERED_DELETED_FILES="${FILTERED_DELETED_FILES}${deleted_file}"$'\n'
    done <<< "$DELETED_FILES"
    DELETED_FILES=$(printf '%s' "$FILTERED_DELETED_FILES")
fi

if [ -n "$DELETED_FILES" ]; then
    if [ "$ALLOW_DELETIONS" != "1" ] && has_human_override_trailer "allow-deletions"; then
        ALLOW_DELETIONS=1
    fi

    if [ "$ALLOW_DELETIONS" != "1" ]; then
        VIOLATIONS=$((VIOLATIONS + 1))
        echo -e "${RED}╔═══════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  ❌ FILE DELETIONS DETECTED - COMMIT BLOCKED                 ║${NC}"
        echo -e "${RED}╚═══════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo "The following files are being deleted:"
        echo "$DELETED_FILES" | sed 's/^/  ❌ /'
        echo ""
        echo -e "${YELLOW}Use 'git mv' to move files instead of deleting.${NC}"
        echo -e "${YELLOW}Human override: git commit --trailer \"allow-deletions=true\"${NC}"
        echo ""
    else
        echo -e "${YELLOW}⚠️  File deletions allowed (human override detected)${NC}"
    fi
fi

if [ -n "$ALLOWED_ARCHIVE_DELETIONS" ]; then
    echo -e "${GREEN}ℹ️  Allowed archive follow-up deletions:${NC}"
    echo "$ALLOWED_ARCHIVE_DELETIONS" | sed '/^$/d; s/^/  ↪ /'
fi

# ═══════════════════════════════════════════════════════════════
# HARD GATE 3: .ALLOWLIST PROTECTION
# ═══════════════════════════════════════════════════════════════

WHITELIST_CHANGES=$(git diff --cached --name-only | grep -E '^\.allowlist$|^\.allowlist ' || true)
if [ -n "$WHITELIST_CHANGES" ]; then
    ALLOWLIST_EDIT=${ALLOWLIST_EDIT:-0}
    if [ "$ALLOWLIST_EDIT" != "1" ]; then
        if has_human_override_trailer "allowlist-edit"; then ALLOWLIST_EDIT=1; fi
    fi

    if [ "$ALLOWLIST_EDIT" != "1" ]; then
        VIOLATIONS=$((VIOLATIONS + 1))
        echo -e "${RED}╔═══════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  .allowlist FILE CHANGES BLOCKED                              ║${NC}"
        echo -e "${RED}╚═══════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo -e "${YELLOW}⚠️  .allowlist is protected. Only humans may edit it.${NC}"
        echo -e "${YELLOW}Human override: git commit --trailer \"allowlist-edit=true\"${NC}"
        echo ""
        exit 1
    else
        echo -e "${YELLOW}⚠️  .allowlist edit allowed (human override detected)${NC}"
    fi
fi

# ═══════════════════════════════════════════════════════════════
# HARD GATE 4: DOCS.JSON REDIRECT INTEGRITY + ROOT STRUCTURE
# ═══════════════════════════════════════════════════════════════

# docs.json /redirect route changes
DOCS_JSON_REDIRECT_DIFF=$(git diff --cached --unified=0 -- docs.json | grep -E '^[+-][^+-].*/redirect' || true)
if [ -n "$DOCS_JSON_REDIRECT_DIFF" ]; then
    DOCS_JSON_REDIRECT_STATUS=$(node - <<'NODE'
const { spawnSync } = require('child_process');

function runGit(args) {
  const result = spawnSync('git', args, { encoding: 'utf8' });
  if (result.status !== 0) return '';
  return String(result.stdout || '');
}

function collectDocsJsonRedirectEntries(raw) {
  if (!raw) return [];
  const docsJson = JSON.parse(raw);
  const entries = [];
  const normalizeTabName = (tabName) => (tabName === 'GPU Nodes' ? 'Orchestrators' : tabName || '');
  const v2Version = Array.isArray(docsJson?.navigation?.versions)
    ? docsJson.navigation.versions.find((entry) => entry && entry.version === 'v2')
    : null;
  const english = Array.isArray(v2Version?.languages)
    ? v2Version.languages.find((entry) => entry && entry.language === 'en')
    : null;

  function visitPages(node, context = { tab: null, anchor: null, group: null }) {
    if (Array.isArray(node)) { node.forEach((item) => visitPages(item, context)); return; }
    if (!node || typeof node !== 'object') return;
    const nextContext = { ...context };
    if (typeof node.tab === 'string') nextContext.tab = node.tab;
    if (typeof node.anchor === 'string') nextContext.anchor = node.anchor;
    if (typeof node.group === 'string') nextContext.group = node.group;
    if (Array.isArray(node.pages)) {
      node.pages.forEach((page) => {
        if (typeof page === 'string' && page.includes('/redirect')) {
          entries.push(
            `page|tab=${normalizeTabName(nextContext.tab)}|anchor=${nextContext.anchor || ''}|group=${nextContext.group || ''}|value=${page}`
          );
        } else { visitPages(page, nextContext); }
      });
    }
    if (Array.isArray(node.anchors)) visitPages(node.anchors, nextContext);
    if (Array.isArray(node.groups)) visitPages(node.groups, nextContext);
  }

  if (english) { visitPages(english.tabs); }

  (docsJson.redirects || []).forEach((entry) => {
    if (!entry || typeof entry !== 'object') return;
    if (typeof entry.source === 'string' && entry.source.includes('/redirect')) {
      entries.push(`redirect|source=${entry.source}|destination=${entry.destination || ''}`);
    }
    if (typeof entry.destination === 'string' && entry.destination.includes('/redirect')) {
      entries.push(`redirect-destination|source=${entry.source || ''}|destination=${entry.destination}`);
    }
  });
  return entries.sort();
}

const headDocs = runGit(['show', 'HEAD:docs.json']);
const stagedDocs = runGit(['show', ':docs.json']);
const stagedScopedDocs =
  runGit(['show', ':tools/config/scoped-navigation/docs-gate-orch.json']) ||
  runGit(['show', 'HEAD:tools/config/scoped-navigation/docs-gate-orch.json']);

const headEntries = collectDocsJsonRedirectEntries(headDocs);
const stagedEntries = collectDocsJsonRedirectEntries(stagedDocs);
const scopedEntries = collectDocsJsonRedirectEntries(stagedScopedDocs);

const sameAsHead = JSON.stringify(stagedEntries) === JSON.stringify(headEntries);
const sameAsScoped = stagedScopedDocs && JSON.stringify(stagedEntries) === JSON.stringify(scopedEntries);

if (sameAsHead || sameAsScoped) { process.stdout.write('ALLOW'); process.exit(0); }

const headSet = new Set(headEntries);
const stagedSet = new Set(stagedEntries);
const removed = headEntries.filter((entry) => !stagedSet.has(entry));
const added = stagedEntries.filter((entry) => !headSet.has(entry));
process.stdout.write(JSON.stringify({ removed, added }, null, 2));
process.exit(1);
NODE
)
    if [ "$?" -ne 0 ]; then
        VIOLATIONS=$((VIOLATIONS + 1))
        echo -e "${RED}╔═══════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  docs.json /redirect CHANGES BLOCKED                         ║${NC}"
        echo -e "${RED}╚═══════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo "$DOCS_JSON_REDIRECT_STATUS" | sed 's/^/  ❌ /'
        echo ""
        echo -e "${YELLOW}Keep docs.json redirect surfaces aligned with tools/config/scoped-navigation/docs-gate-orch.json${NC}"
        echo ""
        WARNINGS+=("❌ docs.json includes blocked semantic '/redirect' changes")
    fi
fi

# Root directory structure against allowlist
if [ "$SKIP_STRUCTURE_CHECK" = "1" ]; then
    echo -e "${YELLOW}⚠️  Structure checks bypassed (SKIP_STRUCTURE_CHECK=1)${NC}"
else
    if [ -f ".allowlist" ]; then
        ALLOWLIST=$(grep -v '^#' .allowlist | grep -v '^$' | tr '\n' '|' | sed 's/|$//')
        if [[ "$CURRENT_BRANCH" == codex/* ]]; then ALLOWLIST="${ALLOWLIST}|.codex"; fi

        if [ -n "$ALLOWLIST" ]; then
            NEW_ROOT_FILES=$(git diff --cached --name-only --diff-filter=A | grep -E '^[^/]+$' | grep -vE "^($ALLOWLIST)$" || true)
            NEW_ROOT_DIRS=$(git diff --cached --name-only --diff-filter=A | grep -E '^[^/]+/' | cut -d'/' -f1 | sort -u | grep -vE "^($ALLOWLIST)$" || true)

            if [ -n "$NEW_ROOT_FILES" ] || [ -n "$NEW_ROOT_DIRS" ]; then
                VIOLATIONS=$((VIOLATIONS + 1))
                echo -e "${RED}╔═══════════════════════════════════════════════════════════════╗${NC}"
                echo -e "${RED}║  UNAUTHORIZED ROOT FILES/DIRECTORIES DETECTED               ║${NC}"
                echo -e "${RED}╚═══════════════════════════════════════════════════════════════╝${NC}"
                echo ""
                if [ -n "$NEW_ROOT_FILES" ]; then
                    echo -e "${RED}Unauthorized root files:${NC}"
                    echo "$NEW_ROOT_FILES" | while IFS= read -r file; do
                        [ -n "$file" ] && echo -e "${RED}  ❌ $file${NC}"
                    done
                fi
                if [ -n "$NEW_ROOT_DIRS" ]; then
                    echo -e "${RED}Unauthorized root directories:${NC}"
                    echo "$NEW_ROOT_DIRS" | while IFS= read -r dir; do
                        [ -n "$dir" ] && echo -e "${RED}  ❌ $dir/${NC}"
                    done
                fi
                echo ""
                echo -e "${YELLOW}Allowed root files/directories are listed in .allowlist${NC}"
                echo ""
                WARNINGS+=("❌ Unauthorized root files/directories")
            fi
        fi
    fi
fi

# ═══════════════════════════════════════════════════════════════
# HARD GATE 5: V1/ FREEZE
# ═══════════════════════════════════════════════════════════════

if [ "$SKIP_STRUCTURE_CHECK" != "1" ]; then
    V1_CHANGES=$(git diff --cached --name-only | grep '^v1/' || true)
    if [ -n "$V1_CHANGES" ]; then
        VIOLATIONS=$((VIOLATIONS + 1))
        echo -e "${RED}╔═══════════════════════════════════════════════════════════════╗${NC}"
        echo -e "${RED}║  v1/ IS FROZEN - NO CHANGES ALLOWED                        ║${NC}"
        echo -e "${RED}╚═══════════════════════════════════════════════════════════════╝${NC}"
        echo ""
        echo "$V1_CHANGES" | while IFS= read -r file; do
            echo -e "${RED}  ❌ $file${NC}"
        done
        echo ""
        echo -e "${RED}Commit blocked. v1/ is immutable.${NC}"
        exit 1
    fi
fi

# ═══════════════════════════════════════════════════════════════
# VERDICT
# ═══════════════════════════════════════════════════════════════

echo ""
if [ $VIOLATIONS -eq 0 ]; then
    echo -e "${GREEN}✓ Pre-commit checks passed (hard gates only)${NC}"
    exit 0
else
    echo -e "${RED}╔═══════════════════════════════════════════════════════════════╗${NC}"
    echo -e "${RED}║  PRE-COMMIT VIOLATIONS DETECTED - COMMIT BLOCKED            ║${NC}"
    echo -e "${RED}╚═══════════════════════════════════════════════════════════════╝${NC}"
    echo ""
    echo -e "${YELLOW}Found $VIOLATIONS violation(s):${NC}"
    for warning in "${WARNINGS[@]}"; do
        echo -e "${RED}  $warning${NC}"
    done
    echo ""
    echo -e "${RED}Fix violations and try again.${NC}"
    exit 1
fi
